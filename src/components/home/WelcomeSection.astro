---
import { Image } from 'astro:assets';
import { ArrowRight } from 'lucide-react';
import TextStyle from '@components/ui/TextStyle.astro';
import { buildSanityImageUrl, type SanityImage, type SanityResolvedLink } from '../../lib/sanity';
import bristolBadge from '../../assets/bristol-inn-badge--ellipse.png';
import ButtonLink from '@components/ui/ButtonLink.astro';
import { AvailabilitySearchForm } from '@components/rooms/AvailabilitySearchForm';

interface Props {
  coverColor?: string;
  welcomeHeading?: string;
  welcomeDescription?: string;
  welcomeCTA?: SanityResolvedLink;
  welcomeImage?: SanityImage;
  heroLeftImage?: SanityImage;
  heroRightImage?: SanityImage;
  galleryImages?: SanityImage[];
  directionsHref?: string;
  directionsLabel?: string;
  reservationHeading?: string;
  reservationHeadingIcon?: SanityImage;
  reservationDescription?: string;
  reservationImage?: SanityImage;
  logo?: string;
}

const { coverColor, welcomeHeading, welcomeDescription, welcomeCTA, heroLeftImage, heroRightImage, reservationHeading, reservationHeadingIcon, reservationDescription, reservationImage } = Astro.props;
const HERO_SLIDE_ANIMATION = false;
const BADGE_ENTRANCE_ANIMATION = false;
---

<div id="welcome-hero" class:list={['fixed w-full bg-white pointer-events-none', HERO_SLIDE_ANIMATION ? 'hero-slide-animation' : 'hero-slide-animation--skipped', HERO_SLIDE_ANIMATION ? (coverColor ? 'fade-in-1000--delay-1000' : 'fade-in-1000') : '']}>
  {
    heroLeftImage?.url && (
      <div class="WelcomeSection___HeroImageContainer">
        <img
          id="WelcomeSection___HeroImage--left"
          src={buildSanityImageUrl(heroLeftImage.url, { width: 1000, height: 1000 })}
          srcset={`${buildSanityImageUrl(heroLeftImage.url, { width: 450, height: 450 })} 450w, ${buildSanityImageUrl(heroLeftImage.url, { width: 900, height: 900 })} 900w`}
          sizes="(max-width: 1280px) 50vw, 740px"
          alt={heroLeftImage.alt}
          width={1200}
          height={800}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          class="w-full h-full object-cover"
        />
      </div>
    )
  }
  {
    heroRightImage?.url && (
      <div class="WelcomeSection___HeroImageContainer">
        <img
          id="WelcomeSection___HeroImage--right"
          src={buildSanityImageUrl(heroRightImage.url, { width: 900, height: 550 })}
          srcset={`${buildSanityImageUrl(heroRightImage.url, { width: 450, height: 450 })} 450w, ${buildSanityImageUrl(heroRightImage.url, { width: 900, height: 900 })} 900w`}
          sizes="(max-width: 1280px) 50vw, 740px"
          alt={heroRightImage.alt}
          width={1200}
          height={800}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          class="w-full h-full object-cover"
        />
      </div>
    )
  }
</div>
<section id="welcome-section">
  <div class="relative z-20">
    <!-- Badge region -->
    <div id="welcome-badge-region" class="flex items-start justify-center h-[var(--welcome-hero-wrapper-h)]">
      <svg aria-hidden="true" focusable="false" class="absolute w-0 h-0 overflow-hidden">
        <defs>
          <clipPath id="badge-oval" clipPathUnits="objectBoundingBox">
            <ellipse cx="0.5" cy="0.5" rx="0.466" ry="0.49"></ellipse>
          </clipPath>
        </defs>
      </svg>
      <div id="bristol-badge" class:list={[BADGE_ENTRANCE_ANIMATION ? 'badge-entrance-animation' : 'badge-entrance-animation--skipped']}>
        <Image src={bristolBadge} alt="Bristol Inn Vermont — Settle In. Stay Awhile." width={240} height={255} class="w-full h-full object-contain" />
      </div>
    </div>
  </div>

  <div id="welcome-prussian-backdrop" aria-hidden="true"></div>

  <div class="relative z-20 w-full py-16 px-[var(--grid-margin)] desktop:mx-0">
    <div id="welcome-section-content" class="flex flex-col bg-white rounded-xl max-w-4xl mx-auto pt-10 px-12 pb-12">
      <!-- Welcome section -->
      <div class="flex mx-auto">
        {
          (welcomeHeading || welcomeDescription || welcomeCTA) && (
            <TextStyle variant="h1" element="p">
              {welcomeHeading && <span class="text-ink-900">{welcomeHeading} </span>}
              {welcomeDescription && <span class="text-iron">{welcomeDescription} </span>}
              {welcomeCTA && (
                <span class="cta-arrow-group inline-flex items-center align-middle gap-1">
                  <ArrowRight size={28} className="cta-arrow text-ink-900" aria-hidden="true" />
                  <ButtonLink size="default" bg="sand-200" class="inline-flex align-middle" href={welcomeCTA.href} target={welcomeCTA.openInNewTab ? '_blank' : undefined} rel={welcomeCTA.openInNewTab ? 'noopener noreferrer' : undefined}>
                    {welcomeCTA.label}
                  </ButtonLink>
                </span>
              )}
            </TextStyle>
          )
        }
      </div>

      <!-- Reservation section -->
      <div class="flex flex-col items-center mb-8 desktop:mx-[64px] mt-[var(--grid-gutter)]">
        {
          reservationImage && (
            <div class="mx-[var(--grid-margin)]  desktop:aspect-[4/3] w-full desktop:w-[33vw] mx-auto my-8 overflow-hidden rounded-xl">
              <img
                src={buildSanityImageUrl(reservationImage.url, { width: 900, height: 700 })}
                srcset={`${buildSanityImageUrl(reservationImage.url, { width: 450, height: 350 })} 450w, ${buildSanityImageUrl(reservationImage.url, { width: 900, height: 700 })} 900w`}
                sizes="(max-width: 1280px) 40vw, 560px"
                alt={reservationImage.alt}
                width={900}
                height={700}
                loading="eager"
                class="w-full h-full object-cover"
              />
            </div>
          )
        }

        <TextStyle variant="h2" class="text-center">{reservationHeading}</TextStyle>
        {
          reservationDescription && (
            <TextStyle variant="paragraph" element="p" class="max-w-2xl mt-2 mb-[var(--grid-gutter)]">
              {reservationDescription}
            </TextStyle>
          )
        }

        <div class="w-full">
          <AvailabilitySearchForm client:visible navigateTo="/rooms-and-suites" />
        </div>

        <div class="flex items-center justify-center mt-[var(--grid-gutter)]">
          {
            reservationHeadingIcon && (
              <div id="reservation-heading-icon" class="w-20 h-20 flex items-center justify-center">
                <img src={buildSanityImageUrl(reservationHeadingIcon.url, { width: 160, height: 160 })} alt={reservationHeadingIcon.alt} width={80} height={80} loading="lazy" decoding="async" class="w-full h-full object-contain" />
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #cover {
    position: absolute;
    inset: 0;
    height: 100vh;
    width: 100vw;
    pointer-events: none;
    z-index: 9;
    will-change: transform;
    animation: coverSlideUp 0.6s ease-in-out 1s forwards;
  }

  @keyframes coverSlideUp {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-100%);
    }
  }

  #welcome-badge-region {
    height: var(--welcome-hero-wrapper-h);
  }

  #welcome-section {
    position: relative;
    isolation: isolate;
  }

  #welcome-hero {
    z-index: 0;
    height: var(--welcome-hero-h);
    will-change: transform, opacity;
  }

  #welcome-hero.is-released {
    position: absolute;
    top: var(--welcome-hero-release-top, 0px);
  }

  #bristol-badge {
    position: sticky;
    top: var(--welcome-badge-sticky-top);
    width: var(--welcome-badge-w);
    max-width: 280px;
    will-change: transform;
  }
  #welcome-section-content {
    transition: box-shadow 0.4s ease;
  }

  #welcome-section-content.shadow-visible {
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.1),
      0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  #welcome-prussian-backdrop {
    position: fixed;
    top: var(--welcome-hero-wrapper-h);
    left: 0;
    z-index: 5;
    width: 100%;
    height: 100vh;
    pointer-events: none;
    background: var(--color-prussian-500);
    transform: translate3d(0, var(--welcome-backdrop-y, 0px), 0);
    will-change: transform;
  }

  #welcome-prussian-backdrop.is-released {
    position: absolute;
    top: var(--welcome-backdrop-release-top, 0px);
    transform: none;
  }

  .WelcomeSection___HeroImageContainer {
    position: absolute;
    overflow: hidden;
    top: var(--welcome-hero-top);
    opacity: 0; /* held by animation-fill-mode: both until animation starts */
    width: var(--welcome-hero-w);
    height: var(--welcome-hero-h);
  }

  .hero-slide-animation .WelcomeSection___HeroImageContainer:has(#WelcomeSection___HeroImage--left) {
    left: 0;
    border-top-right-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
    animation: heroSlideInLeft 0.5s ease-out 0.05s both;
  }

  .hero-slide-animation .WelcomeSection___HeroImageContainer:has(#WelcomeSection___HeroImage--right) {
    right: 0;
    border-top-left-radius: 0.75rem;
    border-bottom-left-radius: 0.75rem;
    animation: heroSlideInRight 0.5s ease-out 0.05s both;
  }

  .hero-slide-animation--skipped .WelcomeSection___HeroImageContainer {
    /* opacity: 0.5; */
    /* transform: translateX(0); */
    animation: fadeInAnimation 0.2s ease-in 0.05s both;
    /* animation: fadeInAnimation 0.05s ease-out 0.75s both; */
  }

  .hero-slide-animation--skipped .WelcomeSection___HeroImageContainer:has(#WelcomeSection___HeroImage--left) {
    left: 0;
    border-top-right-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
  }

  .hero-slide-animation--skipped .WelcomeSection___HeroImageContainer:has(#WelcomeSection___HeroImage--right) {
    right: 0;
    border-top-left-radius: 0.75rem;
    border-bottom-left-radius: 0.75rem;
  }
</style>

<style is:global>
  :root {
    --welcome-hero-top: calc(var(--nav-top-bar-height) + 2 * var(--page-margin));
    /* --welcome-hero-w: calc(50vw - 2 * var(--page-margin)); */
    --welcome-hero-w: calc((100vw - 3 * var(--page-margin)) / 2);
    --welcome-hero-h: calc(var(--welcome-hero-w) * 2);
    --welcome-badge-w: min(42vw, 280px);
    --welcome-badge-h: calc(var(--welcome-badge-w) * 255 / 240);
    --welcome-badge-sticky-top: max(var(--nav-top-bar-height), calc(var(--welcome-hero-top) + (var(--welcome-hero-h) / 2) - (var(--welcome-badge-h) / 2)));
    --welcome-hero-wrapper-h: calc(var(--welcome-hero-h) + 2 * var(--page-margin) + var(--nav-top-bar-height) + 32px);
  }

  @media (min-width: 640px) {
    :root {
      /* --welcome-hero-h: calc(var(--welcome-hero-w) * 2); */

      --welcome-badge-w: min(32vw, 280px);
    }
  }

  @media (min-width: 1024px) {
    :root {
      --welcome-hero-h: calc(100vh - 2 * var(--nav-top-bar-height) - 5 * var(--page-margin));
      --welcome-hero-wrapper-h: calc(100vh - 32px);
      /* --welcome-hero-h: calc(var(--welcome-hero-w) * 3 / 4); */
      /* --welcome-hero-h: calc(100vh - var(--nav-top-bar-height-2x) - 2 * var(--page-margin) - 64px); */
      --welcome-badge-w: min(20vw, 280px);
    }
  }

  .cta-arrow {
    transition: transform 0.2s ease;
    margin-right: 6px;
  }

  .cta-arrow-group:hover .cta-arrow {
    transform: translateX(2px);
  }

  @keyframes heroSlideInLeft {
    from {
      opacity: 0;
      transform: translateX(-100%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes heroSlideInRight {
    from {
      opacity: 0;
      transform: translateX(100%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes badgeEntrance {
    0% {
      scale: 0.2;
      opacity: 0;
    }
    80% {
      scale: 1.06;
      opacity: 1;
    }
    100% {
      scale: 1;
    }
  }

  .badge-entrance-animation {
    animation: badgeEntrance 0.4s ease-in-out 0.35s both;
  }
  .badge-entrance-animation--skipped {
    animation: fadeInAnimation 0.2s ease-in 0.15s both;
  }

  @keyframes fadeInAnimation {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<script define:vars={{ coverColor }}>
  const hero = document.getElementById('welcome-hero');
  const heroLeftImage = document.getElementById('WelcomeSection___HeroImage--left');
  const heroRightImage = document.getElementById('WelcomeSection___HeroImage--right');
  const content = document.getElementById('welcome-section-content');
  const backdrop = document.getElementById('welcome-prussian-backdrop');

  const skipIntro = window.matchMedia('(prefers-reduced-motion: reduce)').matches || window.scrollY > 32;

  if (coverColor && !skipIntro) {
    const cover = document.createElement('div');
    cover.id = 'cover';
    cover.style.backgroundColor = coverColor;
    document.body.appendChild(cover);
  }

  if (skipIntro) {
    const leftContainer = heroLeftImage?.parentElement;
    const rightContainer = heroRightImage?.parentElement;
    if (leftContainer) {
      leftContainer.style.animation = 'none';
      leftContainer.style.opacity = '1';
      leftContainer.style.transform = 'translateX(0)';
    }
    if (rightContainer) {
      rightContainer.style.animation = 'none';
      rightContainer.style.opacity = '1';
      rightContainer.style.transform = 'translateX(0)';
    }
  }

  const CONTENT_SHADOW_SCROLL_PX = 64;
  // Page scroll distance (px) at which the content card's drop shadow fades in.

  function getNavHeight() {
    const navHeight = getComputedStyle(document.documentElement).getPropertyValue('--nav-top-bar-height');
    return Number.parseFloat(navHeight) || 0;
  }

  function updateBackdropPosition() {
    if (!content || !backdrop) return;
    const wasReleased = backdrop.classList.contains('is-released');
    const wasHeroReleased = hero?.classList.contains('is-released') ?? false;
    backdrop.classList.remove('is-released');

    const contentRect = content.getBoundingClientRect();
    const contentTop = contentRect.top;
    const navHeight = getNavHeight();
    const start = window.innerHeight * 0.5;
    const end = navHeight * 2;
    const range = Math.max(1, start - end);
    const progress = Math.min(1, Math.max(0, (start - contentTop + navHeight) / range));
    const startTop = Number.parseFloat(getComputedStyle(backdrop).top) || 0;
    const shouldReleaseHero = progress >= 1;
    const shouldReleaseBackdrop = contentRect.bottom <= window.innerHeight - navHeight;

    if (shouldReleaseHero && hero) {
      if (!wasHeroReleased) {
        hero.style.setProperty('--welcome-hero-release-top', `${window.scrollY.toFixed(2)}px`);
      }
      hero.classList.add('is-released');
    } else {
      hero?.classList.remove('is-released');
    }

    if (shouldReleaseBackdrop) {
      if (!wasReleased) {
        const sectionTop = backdrop.parentElement?.getBoundingClientRect().top ?? 0;
        backdrop.style.setProperty('--welcome-backdrop-release-top', `${(-sectionTop).toFixed(2)}px`);
      }
      backdrop.style.setProperty('--welcome-backdrop-y', `${(-startTop).toFixed(2)}px`);
      backdrop.classList.add('is-released');
      return;
    }

    backdrop.style.setProperty('--welcome-backdrop-y', `${(-startTop * progress).toFixed(2)}px`);
  }

  // Content card shadow fades in after the user scrolls CONTENT_SHADOW_SCROLL_PX
  function updateContentShadow() {
    if (!content) return;
    content.classList.toggle('shadow-visible', window.scrollY >= CONTENT_SHADOW_SCROLL_PX);
  }

  let rafPending = false;

  function onScroll() {
    if (rafPending) return;
    rafPending = true;
    requestAnimationFrame(() => {
      updateBackdropPosition();
      updateContentShadow();
      rafPending = false;
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  window.addEventListener('resize', onScroll, { passive: true });

  // Auto-scroll once on load so the content card overlays the hero without
  // requiring the user to scroll first. Skipped if the user has already
  // scrolled by the time the timer fires, or if they prefer reduced motion.
  // const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // if (!prefersReducedMotion) {
  //   setTimeout(() => {
  //     if (window.scrollY === 0) {
  //       window.scrollTo({ top: AUTO_SCROLL_AMOUNT_PX, behavior: 'smooth' });
  //     }
  //   }, AUTO_SCROLL_DELAY_MS);
  // }
</script>
