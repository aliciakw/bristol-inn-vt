---
import { Image } from 'astro:assets';
import TextStyle from '@components/ui/TextStyle.astro';
import { buildSanityImageUrl, type SanityImage, type SanityResolvedLink } from '../../lib/sanity';
import bristolBadge from '../../assets/bristol-inn-badge.png';
import ButtonLink from '@components/ui/ButtonLink.astro';

interface Props {
  welcomeHeading?: string;
  welcomeDescription?: string;
  welcomeCTA?: SanityResolvedLink;
  welcomeImage?: SanityImage;
  heroLeftImage?: SanityImage;
  heroRightImage?: SanityImage;
  directionsHref?: string;
  directionsLabel?: string;
}

const { welcomeHeading, welcomeDescription, welcomeCTA, welcomeImage, heroLeftImage, heroRightImage, directionsHref, directionsLabel = 'find directions' } = Astro.props;
---

<section id="welcome-section">
  <div id="welcome-hero" class="col-span-6 desktop:col-span-8 h-[400px] tablet:h-[420px] desktop:h-[calc(100vh-140px)] relative overflow-hidden">
    {
      heroLeftImage?.url && (
        <div class="absolute left-0 top-[var(--nav-top-bar-height)] bottom-[var(--grid-margin)] w-[calc(50%-6px)] desktop:w-[calc(50%-8px)] rounded-tr-[12px] rounded-br-[12px] desktop:rounded-tr-xl desktop:rounded-br-xl overflow-hidden">
          <img
            src={buildSanityImageUrl(heroLeftImage.url, { width: 900, height: 550 })}
            srcset={`${buildSanityImageUrl(heroLeftImage.url, { width: 450, height: 275 })} 450w, ${buildSanityImageUrl(heroLeftImage.url, { width: 900, height: 550 })} 900w`}
            sizes="(max-width: 1280px) 50vw, 740px"
            alt={heroLeftImage.alt}
            width={900}
            height={550}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            class="w-full h-full object-cover"
          />
        </div>
      )
    }
    {
      heroRightImage?.url && (
        <div class="absolute right-0 top-[var(--nav-top-bar-height)] bottom-[var(--grid-margin)] w-[calc(50%-6px)] desktop:w-[calc(50%-12px)] rounded-tl-[12px] rounded-bl-[8px] desktop:rounded-tl-[16px] desktop:rounded-bl-[16px] overflow-hidden">
          <img
            src={buildSanityImageUrl(heroRightImage.url, { width: 900, height: 550 })}
            srcset={`${buildSanityImageUrl(heroRightImage.url, { width: 450, height: 275 })} 450w, ${buildSanityImageUrl(heroRightImage.url, { width: 900, height: 550 })} 900w`}
            sizes="(max-width: 1280px) 50vw, 740px"
            alt={heroRightImage.alt}
            width={900}
            height={550}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            class="w-full h-full object-cover"
          />
        </div>
      )
    }
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[42vw] h-[44vw] tablet:w-[32vw] tablet:h-[35vw] desktop:w-[20vw] desktop:h-[24vw] max-w-[280px] max-h-[280px] z-10">
      <div class="w-full mt-4 rounded-full bg-white shadow-lg flex items-center justify-center p-3 desktop:p-5">
        <Image src={bristolBadge} alt="Bristol Inn Vermont — Settle In. Stay Awhile." width={240} height={255} class="w-full h-full object-contain" />
      </div>
    </div>
  </div>
  <div class="px-[var(--grid-margin)]">
    <div class="Section__inner">
      <div class="row-span-1 col-span-6 desktop:col-start-2">
        {
          (welcomeHeading || welcomeDescription || welcomeCTA) && (
            <TextStyle variant="h1" element="p">
              {welcomeHeading && <span class="text-ink-900">{welcomeHeading} </span>}
              {welcomeDescription && <span class="text-iron">{welcomeDescription} </span>}
              {welcomeCTA && (
                <ButtonLink size="default" bg="sand-200" class="inline-flex align-middle" href={welcomeCTA.href} target={welcomeCTA.openInNewTab ? '_blank' : undefined} rel={welcomeCTA.openInNewTab ? 'noopener noreferrer' : undefined}>
                  {welcomeCTA.label}
                </ButtonLink>
              )}
            </TextStyle>
          )
        }
      </div>
    </div>
  </div>
</section>
