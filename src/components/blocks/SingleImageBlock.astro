---
import ImageComponent from '@components/ui/ImageComponent.astro';
import TextStyle from '@components/ui/TextStyle.astro';
import { buildSanityImageUrl } from '../../lib/sanity';

interface Props {
  image?: { url?: string; alt?: string };
  layout?: 'default' | 'fullbleed';
  caption?: string;
  textColor?: string;
  backgroundColor?: string;
}

const { image, layout = 'default', caption, textColor, backgroundColor } = Astro.props;
const url = image?.url;
const isFullbleed = layout === 'fullbleed';
const imgWidth = isFullbleed ? 1400 : 800;
const imgHeight = isFullbleed ? 700 : 500;

const wrapperStyle = [textColor ? `color: ${textColor}` : '', backgroundColor ? `background-color: ${backgroundColor}` : ''].filter(Boolean).join('; ');
---

{
  url && (
    <figure class:list={[isFullbleed ? 'my-8' : 'max-w-prose mx-auto my-8', backgroundColor && 'p-4']} style={wrapperStyle || undefined}>
      <ImageComponent
        src={buildSanityImageUrl(url, { width: imgWidth, height: imgHeight })}
        srcset={`${buildSanityImageUrl(url, { width: imgWidth / 2, height: imgHeight / 2 })} ${imgWidth / 2}w, ${buildSanityImageUrl(url, { width: imgWidth, height: imgHeight })} ${imgWidth}w`}
        alt={(image?.alt ?? '') as string}
        width={imgWidth}
        height={imgHeight}
        loading="lazy"
        fadeIn
        imgClass={isFullbleed ? 'w-full object-cover' : 'w-full'}
      />
      {caption && (
        <figcaption class="mt-2 text-center">
          <TextStyle variant="caption">{caption}</TextStyle>
        </figcaption>
      )}
    </figure>
  )
}
