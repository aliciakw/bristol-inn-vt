---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Rooms - Bristol Inn" description="Browse our available rooms">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <h2 class="text-3xl font-bold mb-4">Our Rooms</h2>
    <p class="text-gray-600 mb-6">
      Room listings will appear here once Hostaway API integration is complete (Phase 2).
    </p>

    <!-- Responsive grid: 1 column mobile, 2 tablet, 3 desktop -->
    <div class="grid grid-cols-1 tablet:grid-cols-2 desktop:grid-cols-3 gap-4">
      <div class="bg-gray-100 p-4 rounded">
        <h3 class="font-bold">Placeholder Room</h3>
        <p class="text-sm text-gray-600">Details coming in Phase 2</p>
      </div>
    </div>
  </div>
</BaseLayout>
