---
import { Image } from 'astro:assets';
import TextStyle from '@components/ui/TextStyle.astro';
import type { SanityTestimonialArrayItem } from '../../lib/sanity';

interface Props {
  testimonial?: SanityTestimonialArrayItem[];
  amenities: string[];
}

const { testimonial, amenities } = Astro.props;

const mid = Math.ceil(amenities.length / 2);
const col1 = amenities.slice(0, mid);
const col2 = amenities.slice(mid);

const cardBgClasses = ['bg-prussian-200', 'bg-sand-200', 'bg-lilac-200'];
---

<section class="px-[var(--grid-margin)] desktop:px-0">
  <div class="Section__inner">
    <div class="row-span-1 col-span-6 desktop:col-start-2 flex flex-col gap-4">
      <TextStyle variant="h2" class="text-sand-050 text-center">
        {`You're in good hands`}
      </TextStyle>
    </div>
    <div class="row-span-1 col-span-6 desktop:col-start-3 desktop:col-span-4 flex flex-col gap-4 mb-12">
      <!-- Amenities card -->
      {
        amenities.length > 0 && (
          <div class="flex-1 relative pt-6">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 bg-khaki-300 px-5 py-2.5 rounded-none">
              <TextStyle variant="h4" element="span" bold class="text-ink-900">
                Popular Amenities
              </TextStyle>
            </div>

            <div class="bg-khaki-200 rounded-[16px] pt-12 desktop:pt-14 pb-8 px-8 desktop:px-10 shadow-sm">
              <div class="flex gap-6 desktop:gap-10">
                <ul class="flex-1 list-disc list-inside space-y-1.5">
                  {col1.map((item) => (
                    <li>
                      <TextStyle variant="h5" element="span" class="text-ink-900">
                        {item}
                      </TextStyle>
                    </li>
                  ))}
                </ul>
                {col2.length > 0 && (
                  <ul class="flex-1 list-disc list-inside space-y-1.5">
                    {col2.map((item) => (
                      <li>
                        <TextStyle variant="h5" element="span" class="text-ink-900">
                          {item}
                        </TextStyle>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          </div>
        )
      }
    </div>
    <!-- Testimonial items -->
    {
      testimonial && testimonial.length > 0 && (
        <>
          <div class="col-span-6 desktop:col-start-2 desktop:col-span-6 flex flex-col desktop:flex-row items-center justify-center gap-4">
            <TextStyle variant="h3" class="text-sand-050 text-center">
              Guest Testimonials
            </TextStyle>
          </div>
          <div class="col-span-6 desktop:col-start-2 desktop:col-span-6 flex flex-col desktop:flex-row items-start gap-4">
            {testimonial.map((item, index) => {
              if (item._type === 'testimonialItem') {
                const cardBgClass = cardBgClasses[index % cardBgClasses.length];
                return (
                  <div class="flex-1 rounded-[16px] p-4 desktop:p-6 shrink-0" class:list={[cardBgClass]}>
                    <TextStyle variant="h5" element="p" class="text-ink-900 leading-snug">
                      &#8220;{item.quote}&#8221;
                    </TextStyle>
                    <div class="mt-2 text-right">
                      <TextStyle variant="h5" element="p" class="text-ink-900 font-medium">
                        &#8212; {item.author}
                      </TextStyle>
                      <TextStyle variant="caption" element="p" class="text-ink-900 mt-0.5">
                        {item.role}
                      </TextStyle>
                    </div>
                  </div>
                );
              } else {
                return (
                  <div class="flex-1  aspect-[4/3]">
                    <Image src={item.url} alt={item.alt} width={600} height={450} format="webp" class="w-full h-full object-cover" />
                  </div>
                );
              }
            })}
          </div>
        </>
      )
    }
  </div>
</section>
