---
import { getSettings } from '../lib/sanity';

export type NavigationVariant = 'sand-050' | 'white' | 'sand-100' | 'forest-400' | 'transparent';
export type NavigationTextColor = 'ink-900' | 'sand-050';

interface Props {
  variant?: NavigationVariant;
  textColor?: NavigationTextColor;
  overlayHero?: boolean;
}

const { variant = 'sand-050', textColor = 'ink-900', overlayHero = false } = Astro.props;

const settings = await getSettings();

const DEFAULT_NAV_LINKS = [
  { label: 'Home', href: '/', openInNewTab: false },
  { label: 'Rooms', href: '/rooms', openInNewTab: false },
  { label: 'Contact', href: '/contact', openInNewTab: false },
] as const;

const sidebarLinks = settings?.sidebarLinks?.length ? settings.sidebarLinks : DEFAULT_NAV_LINKS;

const nameplateLogo = settings?.nameplateLogo ?? null;

const leftCta = settings?.leftCta?.label && settings?.leftCta?.href ? settings.leftCta : { label: settings?.leftCta?.label, href: settings?.leftCta?.href, openInNewTab: false };

const rightCta = settings?.rightCta?.label && settings?.rightCta?.href ? settings.rightCta : { label: settings?.rightCta?.label, href: settings?.rightCta?.href, openInNewTab: false };
---

<header id="nav-top-bar" class:list={['w-full h-[var(--nav-top-bar-height)] z-30 top-0 flex items-center shrink-0 sticky px-2 desktop:px-4', `bg-${variant}`]}>
  <!-- Left (desktop only) -->
  <a href="/">
    <img src={nameplateLogo} alt="Bristol Inn, Vermont" class="max-h-10 desktop:max-h-14 desktop:w-[21vw] object-contain" />
  </a>
  <!-- Right Container -->
  <div class="flex flex-1 items-center justify-end">
    <div class="relative z-[50] py-2 pl-2 flex items-center gap-4">
      {
        leftCta.label && leftCta.href && (
          <a
            href={leftCta.href}
            target={leftCta.openInNewTab ? '_blank' : undefined}
            rel={leftCta.openInNewTab ? 'noopener noreferrer' : undefined}
            class="hidden desktop:inline-flex items-center justify-center h-11 px-5 rounded-full bg-khaki-200 text-ink-900 border border-1 border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] whitespace-nowrap hover:opacity-90 transition-opacity"
          >
            {leftCta.label}
          </a>
        )
      }
      <a
        href={rightCta.href}
        target={rightCta.openInNewTab ? '_blank' : undefined}
        rel={rightCta.openInNewTab ? 'noopener noreferrer' : undefined}
        class="hidden desktop:inline-flex items-center justify-center h-11 px-5 rounded-full bg-lilac-200 text-ink-900 border border-1 border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] whitespace-nowrap hover:opacity-90 transition-opacity"
      >
        {rightCta.label}
      </a>
      <button id="nav-menu-toggle" type="button" aria-label="Open navigation menu" aria-expanded="false" aria-controls="nav-menu" class="burger-icon flex flex-col justify-center items-stretch gap-[8px] shrink-0 cursor-pointer">
        <div class="w-9 h-9 flex flex-col justify-center items-stretch gap-[7px]">
          <span class="line"></span>
          <span class="line"></span>
          <span class="line"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Nav drawer (slides in from right) -->
  <nav id="nav-menu" aria-label="Site navigation" class="fixed inset-y-0 right-0 z-[43] bg-prussian-700 text-white flex flex-col justify-center" aria-hidden="true">
    <!-- Content -->
    <div class="NavDrawer__Content quick-fade-in mb-10 px-[var(--grid-margin)] py-6 flex flex-col gap-12 items-start">
      <!-- Nav links from Sanity -->
      <ul>
        {
          sidebarLinks.map(({ label, href, openInNewTab }) => (
            <li>
              <a href={href} target={openInNewTab ? '_blank' : undefined} rel={openInNewTab ? 'noopener noreferrer' : undefined} class="font-serif text-[36px] leading-[1.5] hover:opacity-60 transition-opacity">
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  <div id="nav-backdrop" class="fixed inset-0 z-42 bg-ink-900/40 opacity-0 pointer-events-none transition-opacity duration-300" aria-hidden="true"></div>
</header>

<style>
  #nav-menu {
    width: 0;
    opacity: 1;
    overflow: hidden;
    transition:
      width 0.35s ease-in-out,
      opacity 0.35s ease-in-out;
  }
  #nav-menu.is-open {
    width: 100%;
    opacity: 1;
    overflow-y: auto;
  }

  #nav-menu .NavDrawer__Content {
    transition-delay: 0.2s;
  }

  #nav-menu.is-open .NavDrawer__Content {
    opacity: 1;
  }
  @media (min-width: 640px) {
    #nav-menu.is-open {
      width: 75%;
    }
  }
  @media (min-width: 1024px) {
    #nav-menu.is-open {
      width: 50%;
    }
  }

  .line {
    height: 2.5px;
    border-radius: 3px;
    background-color: var(--color-ink-900);
    transition: all 0.3s ease-in-out;
    z-index: 40;
  }
  [aria-expanded='true'] .line {
    background-color: var(--color-sand-050);
  }
  [aria-expanded='true'] .line:nth-child(1),
  [aria-expanded='true'] .line:nth-child(2) {
    transition-property: transform;
    transition-duration: 0.15s, 0.2s;
    transition-timing-function: ease-in;
    animation-delay: 0.3s;
    /* Animate translateY first, then rotate after */
  }

  /* Animate only translateY initially */
  /* Use ::after to sequence, or a keyframes for more control */
  [aria-expanded='true'] .line:nth-child(1) {
    transform: translateY(10px) rotate(0deg);
    animation: nav-bar-burger-line1-down-rotate 0.3s forwards;
  }
  [aria-expanded='true'] .line:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
    animation: nav-bar-burger-line3-up-rotate 0.3s forwards;
  }

  [aria-expanded='true'] .line:nth-child(2) {
    /* opacity: 0; */
    width: 0px;
    transition: width 0.3s ease-in-out;
  }

  @keyframes nav-bar-burger-line1-down-rotate {
    0% {
      transform: translateY(0px) rotate(0deg);
    }
    75% {
      transform: translateY(10px) rotate(0deg);
    }
    100% {
      transform: translateY(10px) rotate(45deg);
    }
  }

  @keyframes nav-bar-burger-line3-up-rotate {
    0% {
      transform: translateY(0px) rotate(0deg);
    }
    75% {
      transform: translateY(-8.5px) rotate(0deg);
    }
    100% {
      transform: translateY(-8.5px) rotate(-45deg);
    }
  }

  @keyframes nav-slide-down {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(0);
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-menu-toggle');
  const menu = document.getElementById('nav-menu');
  const backdrop = document.getElementById('nav-backdrop');

  function openMenu() {
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    backdrop?.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    backdrop?.classList.remove('opacity-100');
    document.body.style.overflow = '';
  }

  function toggleMenu() {
    if (toggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    } else {
      openMenu();
    }
  }

  toggle?.addEventListener('click', toggleMenu);
  // close?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    }
  });

  // Hero overlay: switch absolute → sticky once WelcomeSection leaves the viewport
  const header = document.getElementById('nav-top-bar');
  const heroImages = document.getElementById('welcome-hero');

  if (header && heroImages && header.classList.contains('absolute')) {
    function enterSticky() {
      header.classList.replace('absolute', 'sticky');
      header.style.animation = 'nav-slide-down 0.25s ease-out';
      header.addEventListener(
        'animationend',
        () => {
          header.style.animation = '';
        },
        { once: true },
      );
    }

    function exitSticky() {
      header.classList.replace('sticky', 'absolute');
    }

    // Fire when the hero images are almost gone — root shrunk 80px from top
    const observer = new IntersectionObserver(
      ([entry]) => {
        const scrolledPast = !entry.isIntersecting && entry.boundingClientRect.top < 0;
        if (scrolledPast) {
          enterSticky();
        } else if (!scrolledPast && header.classList.contains('sticky')) {
          exitSticky();
        }
      },
      { threshold: 0, rootMargin: '-80px 0px 0px 0px' },
    );

    observer.observe(heroImages);

    // Handle hard-load with scroll offset (e.g. browser back)
    if (window.scrollY > heroImages.offsetTop + heroImages.offsetHeight) {
      header.classList.replace('absolute', 'sticky');
    }
  }
</script>
