---
import { Image } from 'astro:assets';
import TextStyle from '@components/ui/TextStyle.astro';
import { buildSanityImageUrl, type SanityImage, type SanityResolvedLink } from '../../lib/sanity';
import bristolBadge from '../../assets/bristol-inn-badge.png';
import ButtonLink from '@components/ui/ButtonLink.astro';
import GalleryStrip from '@components/home/GalleryStrip.astro';
import ReservationSection from '@components/home/ReservationSection.astro';
import { AvailabilitySearchForm } from '@components/rooms/AvailabilitySearchForm';

interface Props {
  welcomeHeading?: string;
  welcomeDescription?: string;
  welcomeCTA?: SanityResolvedLink;
  welcomeImage?: SanityImage;
  heroLeftImage?: SanityImage;
  heroRightImage?: SanityImage;
  galleryImages?: SanityImage[];
  directionsHref?: string;
  directionsLabel?: string;
  reservationHeading?: string;
  reservationHeadingIcon?: SanityImage;
  reservationDescription?: string;
  reservationImage?: SanityImage;
  logo?: string;
}

const { welcomeHeading, welcomeDescription, welcomeCTA, welcomeImage, heroLeftImage, heroRightImage, directionsHref, directionsLabel = 'find directions', reservationHeading, reservationHeadingIcon, reservationDescription, reservationImage, logo, galleryImages } = Astro.props;
---

<div>
  <div id="welcome-hero" class="fixed w-full z-[-1]">
    {
      heroLeftImage?.url && (
        <div class="welcome-hero-image absolute left-0 w-[calc(50%-6px)] desktop:w-[calc(50%-8px)] rounded-r-xl bg-prussian-700 overflow-hidden">
          <img
            src={buildSanityImageUrl(heroLeftImage.url, { width: 900, height: 550 })}
            srcset={`${buildSanityImageUrl(heroLeftImage.url, { width: 450, height: 275 })} 450w, ${buildSanityImageUrl(heroLeftImage.url, { width: 900, height: 550 })} 900w`}
            sizes="(max-width: 1280px) 50vw, 740px"
            alt={heroLeftImage.alt}
            width={900}
            height={550}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 mix-blend-multiply bg-stone-300 pointer-events-none" aria-hidden="true" />
        </div>
      )
    }
    {
      heroRightImage?.url && (
        <div class="welcome-hero-image absolute right-0 w-[calc(50%-6px)] desktop:w-[calc(50%-8px)] rounded-l-xl bg-prussian-700 overflow-hidden">
          <img
            src={buildSanityImageUrl(heroRightImage.url, { width: 900, height: 550 })}
            srcset={`${buildSanityImageUrl(heroRightImage.url, { width: 450, height: 275 })} 450w, ${buildSanityImageUrl(heroRightImage.url, { width: 900, height: 550 })} 900w`}
            sizes="(max-width: 1280px) 50vw, 740px"
            alt={heroRightImage.alt}
            width={900}
            height={550}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 mix-blend-multiply bg-stone-300 pointer-events-none" aria-hidden="true" />
        </div>
      )
    }
  </div>
  <section id="welcome-section" class="">
    <div class="relative z-[10] sticky">
      <div class="flex items-center justify-center" id="welcome-badge-region">
        <div id="bristol-badge" class="sticky w-[42vw] h-[44vw] tablet:w-[32vw] tablet:h-[35vw] desktop:w-[20vw] desktop:h-[24vw] max-w-[280px] max-h-[280px]">
          <div class="w-full mt-4 rounded-full bg-white shadow-lg flex items-center justify-center p-3 desktop:p-5">
            <Image src={bristolBadge} alt="Bristol Inn Vermont — Settle In. Stay Awhile." width={240} height={255} class="w-full h-full object-contain" />
          </div>
        </div>
      </div>

      <div id="welcome-section-content" class="flex flex-col gap-[var(--grid-gap)] bg-white shadow-lg rounded-xl w-[70vw] mx-auto p-[var(--grid-margin)]">
        <!-- Welcome section -->
        <div class="flex">
          {
            (welcomeHeading || welcomeDescription || welcomeCTA) && (
              <TextStyle variant="h1" element="p">
                {welcomeHeading && <span class="text-ink-900">{welcomeHeading} </span>}
                {welcomeDescription && <span class="text-iron">{welcomeDescription} </span>}
                {welcomeCTA && (
                  <ButtonLink size="default" bg="sand-200" class="inline-flex align-middle" href={welcomeCTA.href} target={welcomeCTA.openInNewTab ? '_blank' : undefined} rel={welcomeCTA.openInNewTab ? 'noopener noreferrer' : undefined}>
                    {welcomeCTA.label}
                  </ButtonLink>
                )}
              </TextStyle>
            )
          }
        </div>

        <!-- Reservation section -->
        <div class="flex flex-col items-center mb-8 desktop:mx-[64px] mt-[var(--grid-margin)]">
          <!-- {logo && <img src={logo} alt="" aria-hidden="true" class="w-24 h-24 object-contain" />} -->

          {
            reservationImage && (
              <div class="mx-[var(--grid-margin)] aspect-[5/3] w-[33vw] mx-auto my-8 overflow-hidden rounded-xl">
                <img
                  src={buildSanityImageUrl(reservationImage.url, { width: 900, height: 700 })}
                  srcset={`${buildSanityImageUrl(reservationImage.url, { width: 450, height: 350 })} 450w, ${buildSanityImageUrl(reservationImage.url, { width: 900, height: 700 })} 900w`}
                  sizes="(max-width: 1280px) 40vw, 560px"
                  alt={reservationImage.alt}
                  width={900}
                  height={700}
                  loading="eager"
                  class="w-full h-full object-cover"
                />
              </div>
            )
          }

          <TextStyle variant="h2" class="text-center">{reservationHeading}</TextStyle>
          {
            reservationDescription && (
              <TextStyle variant="paragraph" element="p" class="max-w-2xl mt-2 mb-[var(--grid-gutter)]">
                {reservationDescription}
              </TextStyle>
            )
          }

          <div class="w-2xl">
            <AvailabilitySearchForm client:visible navigateTo="/rooms-and-suites" />
          </div>

          <div class="flex items-center justify-center mt-[var(--grid-margin)]">
            {
              reservationHeadingIcon && (
                <div class="w-20 h-20 flex items-center justify-center">
                  <img src={buildSanityImageUrl(reservationHeadingIcon.url, { width: 160, height: 160 })} alt={reservationHeadingIcon.alt} width={80} height={80} loading="lazy" decoding="async" class="w-full h-full object-contain" />
                </div>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    #welcome-content {
      margin-top: calc(-1 * var(--welcome-hero-h));
    }

    #welcome-badge-region {
      height: var(--welcome-hero-h);
    }

    .welcome-hero-image {
      opacity: 0;
      animation: heroFadeIn 1s ease-out 0.15s both;
    }
  </style>

  <style is:global>
    :root {
      --welcome-hero-h: 400px;
    }

    @media (min-width: 768px) {
      :root {
        --welcome-hero-h: 420px;
      }
    }

    @media (min-width: 1024px) {
      :root {
        --welcome-hero-h: calc(100vh - 274px);
      }
    }

    @keyframes heroFadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  </style>
</div>
<script>
  const hero = document.getElementById('welcome-hero');
  const gallery = document.getElementById('gallery-strip-wrapper');
  const badge = document.getElementById('bristol-badge');
  const content = document.getElementById('welcome-section-content');

  const GALLERY_TRIGGER_OFFSET = Math.round(window.innerHeight * 0.25) - 32;
  const BADGE_FADE_START = Math.round(window.innerHeight * 0.75);
  const BADGE_FADE_END = 0;
  const BADGE_SPACER = 64 + 16; // gap between badge bottom and content top

  let badgeFixedTop = 0;

  function initBadge() {
    if (!badge) return;
    const badgeRegion = document.getElementById('welcome-badge-region');
    if (!badgeRegion) return;
    // getBoundingClientRect().top is viewport-relative; adding scrollY gives the
    // document-absolute top, which equals the fixed `top` value at scroll=0.
    const regionDocTop = badgeRegion.getBoundingClientRect().top + window.scrollY;
    badgeFixedTop = regionDocTop + (badgeRegion.offsetHeight - badge.offsetHeight) / 2 - 32;
    badge.style.position = 'fixed';
    badge.style.left = '50%';
    badge.style.transform = 'translateX(-50%)';
    badge.style.margin = '0';
    badge.style.top = `${badgeFixedTop}px`;
  }

  if (badge) {
    initBadge();
    window.addEventListener('resize', initBadge, { passive: true });
  }

  function update() {
    const vh = window.innerHeight;

    if (hero && gallery) {
      const galleryTop = gallery.getBoundingClientRect().top;
      const galleryTrigger = vh - GALLERY_TRIGGER_OFFSET;
      hero.style.transform = galleryTop < galleryTrigger ? `translateY(${galleryTop - galleryTrigger}px)` : '';
    }

    if (badge) {
      const badgeTop = badge.getBoundingClientRect().top;
      const badgeHeight = badge.offsetHeight;

      if (hero) {
        if (badgeTop <= BADGE_FADE_START) {
          const progress = Math.min(1, Math.max(0, (BADGE_FADE_START - badgeTop) / (BADGE_FADE_START - BADGE_FADE_END)));
          hero.style.opacity = String(1 - 0.3 * progress);
        } else {
          hero.style.opacity = '';
        }
      }

      // Badge stays fixed until content is BADGE_SPACER below badge bottom;
      // after that badge floats above content maintaining the spacer gap.
      if (content) {
        const contentTop = content.getBoundingClientRect().top;
        const threshold = badgeFixedTop + badgeHeight + BADGE_SPACER;
        badge.style.top = contentTop <= threshold ? `${contentTop - BADGE_SPACER - badgeHeight}px` : `${badgeFixedTop}px`;
      }
    }
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>
