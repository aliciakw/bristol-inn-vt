---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Bristol Inn" description="Get in touch with us">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <h2 class="text-3xl font-bold mb-4">Contact Us</h2>
    <p class="text-gray-600 mb-6">
      Contact form will appear here once backend is configured (Phase 4).
    </p>

    <div class="bg-gray-50 p-8 rounded max-w-md">
      <p class="text-gray-600">
        Email: contact@bristolinn.com<br />
        Phone: (555) 123-4567<br />
        Address: Bristol, VT
      </p>
    </div>
  </div>
</BaseLayout>
