---
/**
 * RoomGallery — purely presentational photo gallery.
 *
 * Displays up to 6 photos (already sliced by hostaway.ts normalization).
 * First photo loads eagerly; remaining photos load lazily in a responsive grid.
 * No JavaScript — static scrollable grid only (carousel is Phase 5 / ROOM-06).
 */

import ImageComponent from '@components/ui/ImageComponent.astro';
import { buildSanityImageUrl } from '@lib/sanity';

interface Props {
  /** Up to 6 photos; already sliced by the Hostaway lib (D-04) */
  photos: Array<{ url: string; caption: string }>;
  roomName: string;
  layout?: 'heroFirst' | 'default';
}

const { photos, roomName, layout = 'default' } = Astro.props;
const heroImage = layout === 'heroFirst' ? photos[0] : null;
const gridImages = layout === 'heroFirst' ? photos.slice(1) : photos;
---

{
  photos.length === 0 ? (
    <div class="bg-gray-100 rounded h-64 flex items-center justify-center">
      <p class="text-gray-500">No photos available</p>
    </div>
  ) : (
    <>
      {heroImage && (
        <ImageComponent
          src={buildSanityImageUrl(photos[0].url, { width: 1200, height: 800 })}
          srcset={`${buildSanityImageUrl(photos[0].url, { width: 600, height: 400 })} 600w, ${buildSanityImageUrl(photos[0].url, { width: 1200, height: 800 })} 1200w`}
          alt={photos[0].caption || `${roomName} — photo 1`}
          width={1200}
          height={800}
          loading="eager"
          fadeIn
          class="w-full rounded-xl aspect-[4/3] overflow-hidden"
          imgClass="w-full h-full object-cover"
        />
      )}
      {gridImages.length > 0 && (
        <div class="grid grid-cols-2 gap-3 mt-3">
          {gridImages.map((p, i) => (
            <ImageComponent
              src={buildSanityImageUrl(p.url, { width: 1200, height: 800 })}
              srcset={`${buildSanityImageUrl(p.url, { width: 600, height: 400 })} 600w, ${buildSanityImageUrl(p.url, { width: 1200, height: 800 })} 1200w`}
              alt={p.caption || `${roomName} — photo ${i + 2}`}
              width={1200}
              height={800}
              loading="lazy"
              fadeIn
              class="w-full rounded-xl overflow-hidden"
              imgClass="w-full h-full object-cover"
            />
          ))}
        </div>
      )}
    </>
  )
}
