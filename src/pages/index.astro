---
import { getHomepage } from '../lib/sanity'
import BaseLayout from '@layouts/BaseLayout.astro'
import HeroCarousel from '../components/HeroCarousel.astro'
import SliceZone from '../components/SliceZone.astro'

const homepage = await getHomepage()
const heroImages = homepage.heroImages.filter(img => img.url)
const ctaLabel = homepage.ctaLabel || 'Browse Our Rooms'
const ctaUrl = homepage.ctaUrl ?? '/rooms'
---
<BaseLayout title="Bristol Inn — Vermont" description="Welcome to Bristol Inn, a Vermont inn with beautiful rooms and a warm atmosphere.">
  {heroImages.length > 0 && <HeroCarousel images={heroImages} ctaLabel={ctaLabel} ctaUrl={ctaUrl} />}
  <div class="max-w-4xl mx-auto px-4 py-8">
    <SliceZone blocks={homepage.body} />
  </div>
</BaseLayout>
