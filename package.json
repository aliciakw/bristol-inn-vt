{
  "name": "bristol-inn-vt",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "description": "Bristol Inn - Astro website",
  "repository": "https://github.com/aliciakw/bristol-inn-vt",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/prebuild.mjs",
    "build": "astro build",
    "preview": "astro build && wrangler dev",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,astro,js,mjs,cjs,json,md,css}\"",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy:studio": "npm --prefix studio-bristol-inn-vt ci && npm --prefix studio-bristol-inn-vt run deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.1",
    "@astrojs/react": "^5.0.7",
    "@portabletext/to-html": "^5.0.2",
    "@sanity/client": "^7.22.1",
    "@sentry/astro": "^10.55.0",
    "@sentry/cloudflare": "^10.53.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.2.2",
    "embla-carousel": "^8.6.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.2.4",
    "wrangler": "^4.92.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "vite": "^7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.astro": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
