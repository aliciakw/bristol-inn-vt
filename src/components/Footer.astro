---
import { toHTML } from '@portabletext/to-html';
import { getSettings } from '../lib/sanity';
import TextStyle from '@components/ui/TextStyle.astro';
import Button from '@components/ui/Button.astro';

const year = new Date().getFullYear();

const settings = await getSettings();
const { footerSections = [], awardImages = [], directionsLink } = settings ?? {};

function sectionToHTML(content: unknown[]): string {
  return toHTML(content as Parameters<typeof toHTML>[0], {
    components: {
      block: {
        normal: ({ children }) => `<p class="font-serif font-[400] text-[17px] leading-[1.6] tracking-[0.02em]">${children}</p>`,
        h4: ({ children }) => `<h4 class="font-serif text-[31px] leading-[1.2] mt-[4rem] mb-6">${children}</h4>`,
        small: ({ children }) => `<p class="font-serif text-[14px] leading-[1.4] tracking-[0.01em]">${children}</p>`,
      },
      marks: {
        em: ({ children }) => `<em>${children}</em>`,
        link: ({ children, value }) => {
          const target = value?.openInNewTab ? ' target="_blank" rel="noopener noreferrer"' : '';
          return `<a href="${value?.href ?? '#'}"${target} class="hover:underline hover:text-sand-200 transition-colors">${children}</a>`;
        },
      },
    },
  });
}
---

<footer class="bg-prussian-500 text-white max-w-[100vw] overflow-x-hidden">
  <div class="grid grid-cols-6 desktop:grid-cols-8 gap-x-8 gap-y-10 px-6 pt-14 pb-6 desktop:gap-x-16 desktop:gap-y-12">
    {
      footerSections.map((section, i) => {
        const isFirst = i === 0;
        return (
          <section class:list={['desktop:col-span-2', isFirst ? 'col-span-6 desktop:col-start-2 desktop:row-start-1 desktop:row-span-3 flex flex-col' : 'col-span-3']}>
            {section.content?.length > 0 && <div set:html={sectionToHTML(section.content)} />}

            {i === footerSections.length - 1 && (
              <section class="col-span-6 desktop:col-span-2 desktop:col-start mt-[var(--grid-gutter)] flex flex-col gap-4">
                <TextStyle variant="h4">Subscribe</TextStyle>
                <TextStyle variant="caption">Our newsletter includes events, deals, and more.</TextStyle>
                <form class="relative">
                  <input type="email" name="email" placeholder="you@email.com" required class="flex-1 h-11 w-full px-5 mr-[-40px] rounded-full bg-sand-100 border border-ink-900 font-serif text-[17px] text-ink-900 placeholder:opacity-50 focus:outline-none focus:ring-2 focus:ring-khaki-200 focus:ring-offset-1" />
                  <Button type="submit" size="small" class="absolute right-0 top-0 h-11 shrink-0" bg="khaki-200">
                    Subscribe
                  </Button>
                </form>
              </section>
            )}
          </section>
        );
      })
    }

    <div class="col-span-6 desktop:col-span-8 text-center">
      <p class="font-serif text-[14px] text-sand-100/80">
        &copy; {year} Bristol Inn Vermont. All rights reserved. | Site by <a href="https://aleeshza.com" target="_blank" rel="noopener noreferrer" class="hover:underline hover:text-sand-200 transition-colors">Aleeshza Studio</a>
      </p>
    </div>
  </div>
</footer>
