---
import ButtonLink from '@components/ui/ButtonLink.astro';
import PageHeaderBlock from './blocks/PageHeaderBlock.astro';
import PortableTextBlock from './blocks/PortableTextBlock.astro';
import SingleImageBlock from './blocks/SingleImageBlock.astro';
import ColumnLayout from './blocks/ColumnLayout.astro';
import { type SanityBlock } from '../lib/sanity';

interface Props {
  blocks: SanityBlock[];
  contrainProseWidth?: boolean;
}

const { blocks, contrainProseWidth } = Astro.props;
---

{
  (blocks ?? []).map((block) => {
    if (block._type === 'block') {
      return <PortableTextBlock block={block} contrainProseWidth={contrainProseWidth} />;
    }

    if (block._type === 'imageBlock') {
      const image = block.image as { url?: string; alt?: string } | undefined;
      const layout = (block.layout as string) === 'full' ? 'fullbleed' : 'default';
      return <SingleImageBlock image={image} layout={layout} caption={block.caption as string | undefined} textColor={block.textColor as string | undefined} backgroundColor={block.backgroundColor as string | undefined} />;
    }

    if (block._type === 'singleImageBlock') {
      const image = block.image as { url?: string; alt?: string } | undefined;
      return <SingleImageBlock image={image} layout={(block.layout as 'default' | 'fullbleed') ?? 'default'} caption={block.caption as string | undefined} textColor={block.textColor as string | undefined} backgroundColor={block.backgroundColor as string | undefined} />;
    }

    if (block._type === 'ctaBlock') {
      const cta = block.cta as { label?: string; href?: string; openInNewTab?: boolean } | undefined;
      if (!cta?.label || !cta?.href) return null;
      const wrapperStyle = [block.textColor ? `color: ${block.textColor}` : '', block.backgroundColor ? `background-color: ${block.backgroundColor}` : ''].filter(Boolean).join('; ');
      return (
        <div class="my-8 flex justify-center" style={wrapperStyle || undefined}>
          <ButtonLink href={cta.href} size="large" bg="prussian-500" textColor="white" target={cta.openInNewTab ? '_blank' : undefined} rel={cta.openInNewTab ? 'noopener noreferrer' : undefined}>
            {cta.label}
          </ButtonLink>
        </div>
      );
    }

    if (block._type === 'pageHeaderBlock') {
      return <PageHeaderBlock block={block as Parameters<typeof PageHeaderBlock>[0]['block']} />;
    }

    if (block._type === 'singleColumnBlock') {
      return <ColumnLayout column1={block.column1 as Parameters<typeof ColumnLayout>[0]['column1']} numColumns={1} textColor={block.textColor as string | undefined} backgroundColor={block.backgroundColor as string | undefined} />;
    }

    if (block._type === 'twoColumnBlock') {
      return <ColumnLayout column1={block.column1 as Parameters<typeof ColumnLayout>[0]['column1']} column2={block.column2 as Parameters<typeof ColumnLayout>[0]['column2']} numColumns={2} textColor={block.textColor as string | undefined} backgroundColor={block.backgroundColor as string | undefined} />;
    }

    if (block._type === 'threeColumnBlock') {
      return (
        <ColumnLayout
          column1={block.column1 as Parameters<typeof ColumnLayout>[0]['column1']}
          column2={block.column2 as Parameters<typeof ColumnLayout>[0]['column2']}
          column3={block.column3 as Parameters<typeof ColumnLayout>[0]['column3']}
          numColumns={3}
          textColor={block.textColor as string | undefined}
          backgroundColor={block.backgroundColor as string | undefined}
        />
      );
    }

    return null;
  })
}
