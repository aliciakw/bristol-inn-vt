---
import { getSettings } from '../lib/sanity'

interface Props {
  variant?: 'sand-100' | 'transparent' | 'forest-400';
  textColor?: 'ink-900' | 'sand-050';
  bookingUrl?: string;
}

const {
  variant = 'sand-100',
  textColor = 'ink-900',
  bookingUrl = '/rooms-and-suites',
} = Astro.props;

const settings = await getSettings()

const DEFAULT_NAV_LINKS = [
  { label: 'Home', href: '/', openInNewTab: false },
  { label: 'Rooms', href: '/rooms', openInNewTab: false },
  { label: 'Contact', href: '/contact', openInNewTab: false },
] as const;

const sidebarLinks = settings?.sidebarLinks?.length
  ? settings.sidebarLinks
  : DEFAULT_NAV_LINKS;
---

<header
  id="nav-top-bar"
  class:list={[
    'w-full h-16 desktop:h-[96px] sticky z-30 top-0 flex items-center shrink-0',
    `bg-${variant}`,
  ]}
>
  <!-- Left (desktop only) -->
  <div class="flex items-center gap-3 desktop:gap-6 pl-4 desktop:pl-6">
    <a
      href="/contact"
      class="hidden desktop:inline-flex items-center justify-center h-11 px-5 rounded-full bg-khaki-200 border border-2 border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] text-ink-900 whitespace-nowrap hover:bg-khaki-300 transition-colors"
    >
      Contact Us
    </a>
  </div>

  <!-- Center: logo -->
  <div class="absolute left-1/2 -translate-x-1/2 text-center pointer-events-none select-none">
    <a href="/" class="pointer-events-auto">
      <p class="font-serif font-medium text-[30px] desktop:text-[2.4375rem] leading-none tracking-[0.01em]" class:list={`text-${textColor}`}>
        The Bristol Inn
      </p>
      <p class="font-serif font-normal text-[11px] desktop:text-[0.875rem] leading-[1.1] tracking-[0.01em] uppercase mt-0.5" class:list={`text-${textColor}`} >
        19 Main Street, Bristol, Vermont, USA
      </p>
    </a>
  </div>

  <!-- Right (desktop only) -->
  <div class="desktop:flex items-center ml-auto pr-4 gap-4">
    <a
      href={bookingUrl}
      class="hidden desktop:inline-flex items-center justify-center h-11 px-5 rounded-full bg-forest-400 border border-2 border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] text-sand-100 whitespace-nowrap hover:opacity-90 transition-opacity"
    >
      Reserve A Room
    </a>
    <button
      id="nav-menu-toggle"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-menu"
      class="burger-icon relative z-[60] flex flex-col justify-center items-center gap-[5px] w-12 h-12 shrink-0 cursor-pointer rounded-full desktop:w-10 desktop:h-10"
    >
      <span class="line"></span>
      <span class="line"></span>
      <span class="line"></span>
    </button>
  </div>
  
</header>

<!-- Nav drawer (slides in from right) -->
<nav
  id="nav-menu"
  aria-label="Site navigation"
  class="fixed inset-y-0 right-0 z-50 bg-lilac-200 flex flex-col pb-12"
  aria-hidden="true"
>
  <!-- Close button -->
  <div class="flex justify-end mb-10 p-3 desktop:pt-7 desktop:pr-4">
    <button
      id="nav-menu-close"
      type="button"
      aria-label="Close navigation menu"
      class="flex items-center justify-center w-10 h-10 cursor-pointer text-ink-900"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M2 2L18 18M18 2L2 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Content -->
  <div class="mb-10 p-6 desktop:p-7 flex flex-col gap-12 items-start">
    <a
      href={bookingUrl}
      class="inline-flex items-center justify-center h-11 px-6 rounded-full bg-lilac-200 border border-2 border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] text-ink-900 hover:bg-lilac-200/70 transition-colors"
    >
      Reserve A Room
    </a>
  

  <!-- Nav links from Sanity -->
    <ul>
      {sidebarLinks.map(({ label, href, openInNewTab }) => (
        <li>
          <a
            href={href}
            target={openInNewTab ? '_blank' : undefined}
            rel={openInNewTab ? 'noopener noreferrer' : undefined}
            class="font-serif font-medium text-[36px] leading-[1.5] text-ink-900 hover:opacity-60 transition-opacity"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<div
  id="nav-backdrop"
  class="fixed inset-0 z-40 bg-ink-900/40 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<style>
  #nav-menu {
    width: 0;
    opacity: 0;
    overflow: hidden;
    transition: width 0.35s ease-in-out, opacity 0.35s ease-in-out;
  }
  #nav-menu.is-open {
    width: 100%;
    opacity: 1;
    overflow-y: auto;
  }
  @media (min-width: 640px) {
    #nav-menu.is-open { width: 75%; }
  }
  @media (min-width: 1024px) {
    #nav-menu.is-open { width: 50%; }
  }

  .line {
    display: block;
    width: 20px;
    height: 2px;
    background-color: var(--color-ink-900);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.3s ease-in-out, opacity 0.3s ease-in-out;
  }
  @media (min-width: 1024px) {
    .line { width: 24px; }
  }

  /* Burger → X when menu is open */
  [aria-expanded="true"] .line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  [aria-expanded="true"] .line:nth-child(2) {
    opacity: 0;
  }
  [aria-expanded="true"] .line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById('nav-menu-toggle');
  const close = document.getElementById('nav-menu-close');
  const menu = document.getElementById('nav-menu');
  const backdrop = document.getElementById('nav-backdrop');

  function openMenu() {
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    backdrop?.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    backdrop?.classList.remove('opacity-100');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    }
  });
</script>
