---
import BaseLayout from '@layouts/BaseLayout.astro';
import { RoomBrowser } from '../components/rooms/RoomBrowser';
import { getPage } from '../lib/sanity';
import { getRooms } from '../lib/hostaway';
import PageHeader from '../components/PageHeader.astro';
import SliceZone from '../components/SliceZone.astro';

const [page, rooms] = await Promise.all([getPage('rooms-and-suites'), getRooms()]);

const pageTitle = page?.title || 'Rooms & Suites';

const browserRooms = rooms.map((r) => ({
  id: r.id,
  name: r.name,
  bedroomsLabel: r.bedroomsLabel,
  price: r.price,
  personCapacity: r.personCapacity,
  floorNumber: r.floorNumber,
  dogsAllowed: r.dogsAllowed,
  photo: r.photos[0] ?? { url: '', caption: '' },
  amenities: r.amenityNames.slice(0, 3),
}));
---

<BaseLayout title={`${pageTitle} — Bristol Inn`} meta={page?.meta} backgroundColor="white" navigationVariant="transparent" offsetNavigation>
  {page?.pageHeader && <PageHeader block={page.pageHeader} className="pb-16" />}

  <div class="Section mt-[var(--grid-gutter)]">
    <div class="Section__inner">
      <div class="row-span-1 col-span-6 desktop:col-span-8">
        <RoomBrowser client:load rooms={browserRooms} />
      </div>
    </div>
  </div>
</BaseLayout>
