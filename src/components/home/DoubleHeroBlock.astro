---
import { Image } from 'astro:assets';
import { buildSanityImageUrl, type SanityImage } from '../../lib/sanity';
import bristolBadge from '../../assets/bristol-inn-badge--ellipse.png';

interface Props {
  leftImage?: SanityImage;
  rightImage?: SanityImage;
  showLogoBadge?: boolean;
}

const { leftImage, rightImage, showLogoBadge = false } = Astro.props;
const HERO_SLIDE_ANIMATION = false;
const BADGE_ENTRANCE_ANIMATION = false;
---

<section
  id="double-hero-block"
  class="DoubleHero__Wrapper"
  class:list={[
    'relative w-full flex items-center justify-center bg-white pointer-events-none',
    HERO_SLIDE_ANIMATION ? 'hero-slide-animation fade-in-100' : 'hero-slide-animation--skipped',
  ]}
>
  {
    showLogoBadge && (
      <div
        id="bristol-badge"
        class="absolute left-1/2 top-1/2 z-10 w-[min(42vw,240px)] -translate-x-1/2 -translate-y-1/2"
        class:list={[BADGE_ENTRANCE_ANIMATION ? 'badge-entrance-animation' : 'badge-entrance-animation--skipped']}
      >
        <Image src={bristolBadge} alt="Bristol Inn Vermont — Settle In. Stay Awhile." width={240} height={255} class="h-auto w-full object-contain" />
      </div>
    )
  }
  {
    leftImage?.url && (
      <div class="DoubleHero___ImageContainer rounded-[16px] absolute left-0">
        <img
          id="DoubleHero___Image--left"
          src={buildSanityImageUrl(leftImage.url, { width: 1000, height: 1000 })}
          srcset={`${buildSanityImageUrl(leftImage.url, { width: 450, height: 450 })} 450w, ${buildSanityImageUrl(leftImage.url, { width: 900, height: 900 })} 900w`}
          sizes="(max-width: 1280px) 50vw, 740px"
          alt={leftImage.alt}
          width={1200}
          height={800}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          class="w-full h-full object-cover"
        />
      </div>
    )
  }
  {
    rightImage?.url && (
      <div class="DoubleHero___ImageContainer rounded-[16px] absolute right-0">
        <img
          id="DoubleHero___Image--right"
          src={buildSanityImageUrl(rightImage.url, { width: 900, height: 550 })}
          srcset={`${buildSanityImageUrl(rightImage.url, { width: 450, height: 450 })} 450w, ${buildSanityImageUrl(rightImage.url, { width: 900, height: 900 })} 900w`}
          sizes="(max-width: 1280px) 50vw, 740px"
          alt={rightImage.alt}
          width={1200}
          height={800}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          class="w-full h-full object-cover"
        />
      </div>
    )
  }
</section>

<style>
  :root {
    --double-hero-wrapper-h: 80vh;
    --double-hero-image-h: calc(var(--double-hero-wrapper-h) - 72px);
    --double-hero-image-w: calc(50vw - var(--grid-gutter));
  }

  @media (min-width: 960px) {
    :root {
    }
  }

  @media (min-width: 1224px) {
    :root {
    }
  }
  .DoubleHero__Wrapper {
    height: var(--double-hero-wrapper-h);
  }
  .DoubleHero___ImageContainer {
    position: absolute;
    overflow: hidden;
    /* opacity: 0; /* held by animation-fill-mode: both until animation starts */
    width: var(--double-hero-image-w);
    height: var(--double-hero-image-h);
  }
  .DoubleHero___ImageContainer:has(#DoubleHero___Image--left) {
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    animation: heroSlideInLeft 0.5s ease-out 0.05s both;
  }

  .DoubleHero___ImageContainer:has(#DoubleHero___Image--right) {
    animation: heroSlideInRight 0.5s ease-out 0.05s both;
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
  }
</style>

<script></script>
