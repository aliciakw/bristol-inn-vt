# ─────────────────────────────────────────────────────────────────────────────
# Bristol Inn — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in all values.
# .env.local is git-ignored and must NEVER be committed to the repository.
#
# For Cloudflare Pages production: configure all vars in the Cloudflare
# project dashboard → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Hostaway API Bearer token (server-only; keep secret)
# Pre-generated long-lived token from the Hostaway dashboard.
# Used as: Authorization: Bearer <token> on all /v1/listings API calls.
HOSTAWAY_ACCESS_TOKEN=your_hostaway_access_token_here

# Prismic CMS access token (server-only; keep secret)
# Generate at: https://bristol-inn-vt.prismic.io → Settings → API & Security
PRISMIC_TOKEN=your_prismic_access_token_here

# Sentry authentication token (server-only; optional)
# Used only at build time to upload source maps to Sentry.
# Generate at: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# Sentry DSN (PUBLIC — visible in client JS; optional)
# Found in: Sentry project → Settings → Client Keys (DSN)
PUBLIC_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/0

# Google Analytics 4 Measurement ID (PUBLIC — visible in client JS; optional)
# Format: G-XXXXXXXXXX — found in GA4 dashboard → Admin → Data Streams
PUBLIC_GA4_ID=G-XXXXXXXXXX
