---
import { buildSanityImageUrl, type SanityImage } from '../../lib/sanity';

interface Props {
  images: SanityImage[];
}

const { images } = Astro.props;
const visible = images.filter((img) => img.url);
---

{
  visible.length > 0 && (
    <div class=" w-full relative overflow-hidden">
      <div class="flex w-max gallery-scroll">
        {[...visible, ...visible].map((img) => (
          <div class="flex-none w-[20vw] rounded-lg aspect-square overflow-x-hidden mr-[var(--page-margin)]">
            <img src={buildSanityImageUrl(img.url, { width: 400, height: 400 })} alt={img.alt} width={192} height={192} loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
        ))}
      </div>
    </div>
  )
}

<style>
  @keyframes gallery-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .gallery-scroll {
    animation: gallery-scroll 200s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-scroll {
      animation: none;
    }
  }
</style>
