---
import TextStyle from '@components/ui/TextStyle.astro';

interface Props {
  testimonial?: { quote: string; author: string; role: string };
  amenities: string[];
}

const { testimonial, amenities } = Astro.props;

// Split amenities into two columns
const mid = Math.ceil(amenities.length / 2);
const col1 = amenities.slice(0, mid);
const col2 = amenities.slice(mid);
---

<section class="px-[var(--grid-margin)] desktop:px-0 pt-12">
  <div class="Section__inner">
    <div class="row-span-1 col-span-6 desktop:col-start-2 flex flex-col gap-4">
      <TextStyle variant="h2" class="text-sand-050 text-center">
        {`You're in good hands`}
      </TextStyle>
    </div>
    <div class="row-span-1 col-span-6 desktop:col-start-3 desktop:col-span-4 flex flex-col desktop:flex-row-reverse gap-4">
      <!-- Amenities card -->
      {
        amenities.length > 0 && (
          <div class="flex-1 relative pt-6">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 bg-khaki-300 px-5 py-2.5 rounded-none">
              <TextStyle variant="h4" element="span" bold class="text-ink-900">
                Popular Amenities
              </TextStyle>
            </div>

            <div class="bg-khaki-200 rounded-[16px] pt-12 desktop:pt-14 pb-8 px-8 desktop:px-10 shadow-sm">
              <div class="flex gap-6 desktop:gap-10">
                <ul class="flex-1 list-disc list-inside space-y-1.5">
                  {col1.map((item) => (
                    <li>
                      <TextStyle variant="h5" element="span" class="text-ink-900">
                        {item}
                      </TextStyle>
                    </li>
                  ))}
                </ul>
                {col2.length > 0 && (
                  <ul class="flex-1 list-disc list-inside space-y-1.5">
                    {col2.map((item) => (
                      <li>
                        <TextStyle variant="h5" element="span" class="text-ink-900">
                          {item}
                        </TextStyle>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          </div>
        )
      }
    </div>
    <!-- Testimonial card -->
    {
      testimonial && (
        <div class="bg-lilac-200 rounded-[16px] p-4 desktop:p-6 col-span-6 desktop:col-start-2 desktop:col-span-3 shrink-0">
          <TextStyle variant="h5" element="p" class="text-ink-900 leading-snug">
            &#8220;{testimonial.quote}&#8221;
          </TextStyle>
          <div class="mt-2 text-right">
            <TextStyle variant="h5" element="p" class="text-ink-900 font-medium">
              &#8212; {testimonial.author}
            </TextStyle>
            <TextStyle variant="caption" element="p" class="text-ink-900 mt-0.5">
              {testimonial.role}
            </TextStyle>
          </div>
        </div>
      )
    }
  </div>
</section>
