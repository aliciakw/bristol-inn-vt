---
import { getRooms, type Room } from '../../lib/rooms';
import BaseLayout from '@layouts/BaseLayout.astro';
import RoomGallery from '../../components/RoomGallery.astro';
import AmenityBadge from '../../components/AmenityBadge.astro';
import { RoomDetailHeader } from '../../components/rooms/RoomDetailHeader';
import PortableTextBlock from '../../components/blocks/PortableTextBlock.astro';
import TextStyle from '@components/ui/TextStyle.astro';

export async function getStaticPaths() {
  const rooms = await getRooms();
  return rooms.map((room) => ({
    params: { id: String(room.id) },
    props: { room },
  }));
}

type Props = { room: Room };
const { room } = Astro.props;
const metaDescription = room.description.slice(0, 160);
const [heroImage, ...images] = room.photos;
---

<BaseLayout title={`${room.name} — Bristol Inn`} description={metaDescription} navigationVariant="transparent" mainClass="Spacer--page-bottom">
  <section class="Section Spacer--navigation-offset relative">
    <a
      id="back-to-rooms"
      href="/rooms-and-suites"
      class="absolute left-[var(--grid-margin)] top-[var(--nav-top-bar-height)] z-20 text-sm text-iron hover:text-ink-900 transition-colors w-fit"
    >
      ← Back to Rooms
    </a>
    <div class="Grid items-start min-h-[100vh] align-start">
      <div
        class="row-span-1 col-span-6 tablet:col-span-4 desktop:col-span-5 tablet:pr-[var(--grid-margin)] flex flex-col gap-8 tablet:sticky tablet:top-[var(--nav-top-bar-height-2x)] tablet:self-start tablet:max-h-[calc(100vh-var(--nav-top-bar-height))] tablet:overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden pb-2"
      >
        <img
          src={room.photos[0].url}
          alt={room.photos[0].caption || `${room.name}`}
          width={1200}
          height={900}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          class="w-full object-cover rounded-xl top aspect-[4/3] mt-12 tablet:hidden"
        />
        <div class="tablet:mt-18 mb-8">
          <RoomDetailHeader
            roomId={room.id}
            name={room.name}
            bedroomsLabel={room.bedroomsLabel}
            personCapacity={room.personCapacity}
            floorNumber={room.floorNumber}
            basePrice={room.price}
          />
        </div>
        <TextStyle variant="paragraph" class="font-bold tablet:mt-4">Description</TextStyle>
        <TextStyle variant="caption" class="leading-relaxed text-gray-700">{room.description}</TextStyle>
        {
          room.specialInstructions?.length ? (
            <div class="flex flex-col gap-4">
              <TextStyle variant="paragraph" class="font-bold">
                Special Instructions
              </TextStyle>
              <div class="flex flex-col gap-3 text-gray-700">
                {room.specialInstructions.map((block) => (
                  <PortableTextBlock block={block} contrainProseWidth={false} />
                ))}
              </div>
            </div>
          ) : null
        }
        <TextStyle variant="paragraph" class="font-bold">Amenities</TextStyle>
        <div class="flex flex-wrap gap-2 desktop:pb-[var(--nav-top-bar-height)]">
          {room.amenityNames.map((a) => <AmenityBadge label={a} />)}
        </div>
      </div>
      <!-- Right column -->
      <div class="row-span-1 col-span-6 tablet:col-span-4 desktop:col-span-7 Xrounded-xl overflow-hidden">
        <TextStyle variant="paragraph" class="font-bold my-4 tablet:hidden">Gallery</TextStyle>
        <RoomGallery photos={room.photos} roomName={room.name} layout="heroFirst" />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function formatRoomDate(iso: string): string {
    const [year, month, day] = iso.split('-').map(Number);
    return new Date(year, month - 1, day).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  const sp = new URLSearchParams(window.location.search);
  const start = sp.get('start');
  const end = sp.get('end');
  const guests = sp.get('numberOfGuests');
  if (start && end && guests) {
    const back = new URLSearchParams({ checkIn: start, checkOut: end, guests });
    if (sp.get('pets') === '1') back.set('pets', '1');
    document.getElementById('back-to-rooms')?.setAttribute('href', `/rooms-and-suites?${back.toString()}`);

    const header = document.querySelector<HTMLElement>('[data-room-detail-header]');
    const roomId = header?.dataset.roomId;
    const parsedGuests = Number.parseInt(guests, 10);
    if (header && roomId && parsedGuests > 0) {
      const rawPrice = Number.parseFloat(sp.get('pricePerNight') ?? '');
      const basePrice = Number.parseFloat(header.dataset.basePrice ?? '');
      const pricePerNight = Number.isFinite(rawPrice) ? rawPrice : basePrice;
      const checkout = new URLSearchParams({ start, end, numberOfGuests: String(parsedGuests) });

      // eslint-disable-next-line @typescript-eslint/no-non-null-assertion
      header.querySelector<HTMLElement>('[data-booking-price]')!.textContent = `$${Math.round(pricePerNight)} / night`;
      // eslint-disable-next-line @typescript-eslint/no-non-null-assertion
      header.querySelector<HTMLElement>('[data-booking-date]')!.textContent = ` · ${formatRoomDate(start)} – ${formatRoomDate(end)}`;
      // eslint-disable-next-line @typescript-eslint/no-non-null-assertion
      header.querySelector<HTMLElement>('[data-booking-guests]')!.textContent = ` · ${parsedGuests} ${parsedGuests === 1 ? 'guest' : 'guests'}`;
      header.querySelector<HTMLElement>('[data-booking-details]')?.classList.remove('hidden');
      header.querySelector<HTMLElement>('[data-default-booking-link]')?.classList.add('hidden');
      const bookingLink = header.querySelector<HTMLElement>('[data-search-booking-link]');
      bookingLink?.classList.remove('hidden');
      bookingLink?.querySelector('a')?.setAttribute('href', `https://bristolsuites.holidayfuture.com/checkout/${roomId}?${checkout.toString()}`);
    }
  }
</script>
