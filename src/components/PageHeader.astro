---
import ImageComponent from '@components/ui/ImageComponent.astro';
import SliceZone from './SliceZone.astro';
import { buildSanityImageUrl, type SanityBlock, type SanityImage, type SanityPageHeader } from '../lib/sanity';

interface Props {
  block: SanityPageHeader;
  introduction?: SanityBlock[];
  className?: string;
}

const { block, className } = Astro.props;
const { introduction, heroImage, textColor, backgroundColor = 'var(--color-prussian-100)' } = block;
---

<div class="Section" style={`background-color: ${backgroundColor}; color: ${textColor};`}>
  <div class="Grid" class:list={[className]}>
    <div class="row-span-1 col-span-3 desktop:col-span-6 pt-44 gap-6">
      <div class="hidden tablet:flex flex-col gap-4 max-w-xl">
        {introduction && introduction.length > 0 && <SliceZone blocks={introduction} contrainProseWidth={false} />}
      </div>
    </div>
    {
      heroImage?.url && (
        <ImageComponent
          src={buildSanityImageUrl(heroImage.url, { width: 900, height: 700 })}
          srcset={`${buildSanityImageUrl(heroImage.url, { width: 450, height: 350 })} 450w, ${buildSanityImageUrl(heroImage.url, { width: 900, height: 700 })} 900w`}
          sizes="(max-width: 1280px) 40vw, 560px"
          alt={heroImage.alt}
          width={900}
          height={700}
          loading="eager"
          fadeIn
          class="row-span-1 col-span-3 desktop:col-span-6 overflow-hidden aspect-[5/3.5] rounded-bl-[16px] rounded-br-[16px]"
          imgClass="w-full h-full object-cover"
        />
      )
    }
    <div class="row-span-1 col-span-6 tablet:hidden flex flex-col gap">
      {introduction && introduction?.length > 0 && <SliceZone blocks={introduction} />}
    </div>
    <slot />
  </div>
</div>
