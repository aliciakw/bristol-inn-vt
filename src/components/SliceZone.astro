---
import { toHTML } from '@portabletext/to-html'
import { Image } from 'astro:assets'
import type { SanityBlock } from '../lib/sanity'

interface Props {
  blocks: SanityBlock[]
}

const { blocks } = Astro.props
---

{(blocks ?? []).map((block) => {
  if (block._type === 'block') {
    return (
      <div
        class="text-base leading-relaxed max-w-prose my-6"
        set:html={toHTML([block as SanityBlock])}
      />
    );
  }

  if (block._type === 'imageBlock') {
    const image = block.image as { asset?: { url?: string }; alt?: string } | undefined;
    const url = image?.asset?.url;
    if (!url) return null;

    const isFullWidth = (block.layout as string) === 'full';
    const caption = block.caption as string | null | undefined;

    return (
      <figure class={isFullWidth ? 'my-6' : 'max-w-prose mx-auto my-6'}>
        <Image
          src={url}
          alt={(image?.alt ?? '') as string}
          width={isFullWidth ? 1200 : 800}
          height={isFullWidth ? 600 : 500}
          format="webp"
          loading="lazy"
          class={isFullWidth ? 'w-full object-cover' : 'w-full'}
        />
        {caption && (
          <figcaption class="text-sm mt-1 text-center">
            {caption}
          </figcaption>
        )}
      </figure>
    );
  }

  return null;
})}
