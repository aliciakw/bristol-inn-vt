---
import NavigationTopBar, { type NavigationVariant, type NavigationTextColor } from '@components/NavigationTopBar.astro';
import Footer from '@components/Footer.astro';
import { getSettings } from '../lib/sanity';
import type { SanityMeta } from '../lib/sanity';
import '@styles/global.css';

interface Props {
  title: string;
  description?: string; // plain-string fallback for non-CMS pages
  meta?: SanityMeta; // Sanity-backed meta for CMS pages
  backgroundColor?: 'sand-050' | 'white' | 'sand-100' | 'forest-400';
  navigationVariant?: NavigationVariant;
  textColor?: NavigationTextColor;
}

const { title, description, meta: pageMeta, backgroundColor = 'sand-050', textColor = 'ink-900', navigationVariant } = Astro.props;

const settings = await getSettings();
const siteMeta = settings?.meta;

const resolvedTitle = pageMeta?.ogTitle ?? title;
const resolvedDescription = pageMeta?.ogDescription ?? description ?? siteMeta?.ogDescription;
const resolvedOgImage = pageMeta?.ogImage?.url ?? siteMeta?.ogImage?.url;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{resolvedTitle}</title>
    {resolvedDescription && <meta name="description" content={resolvedDescription} />}

    <!-- Open Graph -->
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:type" content="website" />
    {resolvedDescription && <meta property="og:description" content={resolvedDescription} />}
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    {resolvedDescription && <meta name="twitter:description" content={resolvedDescription} />}
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
  </head>
  <body class:list={['flex flex-col min-h-screen font-serif', `bg-${backgroundColor}`, `text-${textColor}`]}>
    <div class="flex flex-col flex-1">
      <NavigationTopBar variant={navigationVariant} textColor={textColor} />
      <main class="flex-1 mb-16 desktop:mb-24">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>
