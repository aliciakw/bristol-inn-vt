---
import { Image } from 'astro:assets';
import TextStyle from '@components/ui/TextStyle.astro';
import type { SanityImage, SanityResolvedLink } from '../../lib/sanity';
import bristolLogo from '../../assets/bristol-inn-logo.png';

interface Props {
  welcomeHeading?: string;
  welcomeDescription?: string;
  welcomeCTA?: SanityResolvedLink;
  welcomeImage?: SanityImage;
  directionsHref?: string;
  directionsLabel?: string;
}

const {
  welcomeHeading,
  welcomeDescription,
  welcomeCTA,
  welcomeImage,
  directionsHref,
  directionsLabel = 'find directions',
} = Astro.props;
---

<section>
  <div class="px-[var(--grid-margin)]">
    <div class="Section__inner">
      <div class="row-span-1 col-span-6 desktop:col-start-2">
        {
          (welcomeHeading || welcomeDescription) && (
            <TextStyle variant="h1" element="p">
              {welcomeHeading && <span class="text-ink-900">{welcomeHeading} </span>}
              {welcomeDescription && <span class="text-iron">{welcomeDescription}</span>}
            </TextStyle>
          )
        }
        {
          welcomeCTA && (
            <a
              href={welcomeCTA.href}
              target={welcomeCTA.openInNewTab ? '_blank' : undefined}
              rel={welcomeCTA.openInNewTab ? 'noopener noreferrer' : undefined}
              class="inline-flex items-center px-6 py-2.5 rounded-full border-2 border-ink-900 bg-sand-100 font-serif text-ink-900 text-[18px] hover:bg-sand-200 transition-colors mt-4"
            >
              {welcomeCTA.label}
            </a>
          )
        }
      </div>
      <div class="col-span-2 desktop:col-start-2">
        <!-- Address card -->
        <div
          class="bg-white h-full shadow-md flex flex-col items-center justify-between p-6 desktop:p-8 gap-4"
        >
          <Image
            src={bristolLogo}
            alt="Bristol Inn Vermont"
            width={280}
            height={280}
            class="w-full max-w-[240px] desktop:max-w-[280px] object-contain"
          />
          <div class="text-center">
            <TextStyle
              variant="paragraph"
              element="p"
              class="text-ink-900 underline decoration-solid leading-snug"
            >
              11 Main Street,<br />Bristol, VT 05401
            </TextStyle>
            {
              directionsHref && (
                <a
                  href={directionsHref}
                  class="font-serif text-caption desktop:text-caption-desktop text-ink-900 uppercase tracking-wide mt-1 inline-block hover:underline"
                >
                  {directionsLabel}
                </a>
              )
            }
          </div>
        </div>
      </div>
      <div class="col-span-4">
        {
          welcomeImage?.url && (
            <div class="flex-1 rounded-[16px] overflow-hidden">
              <Image
                src={welcomeImage.url}
                alt={welcomeImage.alt}
                width={825}
                height={550}
                format="webp"
                loading="eager"
                class="w-full h-full object-cover"
              />
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
