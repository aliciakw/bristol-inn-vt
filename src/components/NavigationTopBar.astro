---
import { getSettings } from '../lib/sanity';

export type NavigationVariant = 'sand-050' | 'white' | 'sand-100' | 'forest-400';
export type NavigationTextColor = 'ink-900' | 'sand-050';

interface Props {
  variant?: NavigationVariant;
  textColor?: NavigationTextColor;
}

const { variant = 'sand-050', textColor = 'ink-900' } = Astro.props;

const settings = await getSettings();

const DEFAULT_NAV_LINKS = [
  { label: 'Home', href: '/', openInNewTab: false },
  { label: 'Rooms', href: '/rooms', openInNewTab: false },
  { label: 'Contact', href: '/contact', openInNewTab: false },
] as const;

const sidebarLinks = settings?.sidebarLinks?.length ? settings.sidebarLinks : DEFAULT_NAV_LINKS;

const nameplateLogo = settings?.nameplateLogo ?? null;

const leftCta = settings?.leftCta?.label && settings?.leftCta?.href ? settings.leftCta : { label: settings?.leftCta?.label, href: settings?.leftCta?.href, openInNewTab: false };

const rightCta = settings?.rightCta?.label && settings?.rightCta?.href ? settings.rightCta : { label: settings?.rightCta?.label, href: settings?.rightCta?.href, openInNewTab: false };
---

<header id="nav-top-bar" class:list={['w-full h-16 desktop:h-[96px] sticky z-30 top-0 flex items-center shrink-0 pr-[50px]', `bg-${variant}`]}>
  <!-- Left (desktop only) -->
  <div class="flex items-center gap-3 desktop:gap-6 pl-4 desktop:pl-6">
    <a
      href={leftCta.href}
      target={leftCta.openInNewTab ? '_blank' : undefined}
      rel={leftCta.openInNewTab ? 'noopener noreferrer' : undefined}
      class="hidden desktop:inline-flex items-center justify-center h-11 px-5 rounded-full bg-khaki-200 border border-2 border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] text-ink-900 whitespace-nowrap hover:bg-khaki-300 transition-colors"
    >
      {leftCta.label}
    </a>
  </div>

  <!-- Center: logo -->
  <div class="absolute left-1/2 -translate-x-1/2 text-center pointer-events-none select-none">
    <a href="/" class="pointer-events-auto">
      {
        nameplateLogo ? (
          <img src={nameplateLogo} alt="Bristol Inn, Vermont" class="max-h-10 desktop:max-h-14 w-auto object-contain" />
        ) : (
          <>
            <p class="font-serif font-medium text-[30px] desktop:text-[2.4375rem] leading-none tracking-[0.01em]" class:list={`text-${textColor}`}>
              The Bristol Inn
            </p>
            <p class="font-serif font-normal text-[11px] desktop:text-[0.875rem] leading-[1.1] tracking-[0.01em] uppercase mt-0.5" class:list={`text-${textColor}`}>
              19 Main Street, Bristol, Vermont, USA
            </p>
          </>
        )
      }
    </a>
  </div>

  <!-- Right (desktop only) -->
  <div class="desktop:flex items-center ml-auto pr-4 gap-4">
    <a
      href={rightCta.href}
      target={rightCta.openInNewTab ? '_blank' : undefined}
      rel={rightCta.openInNewTab ? 'noopener noreferrer' : undefined}
      class="hidden desktop:inline-flex items-center justify-center h-11 px-5 rounded-full bg-forest-400 border border-2 border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] text-sand-100 whitespace-nowrap hover:opacity-90 transition-opacity"
    >
      {rightCta.label}
    </a>
  </div>
</header>

<button id="nav-menu-toggle" type="button" aria-label="Open navigation menu" aria-expanded="false" aria-controls="nav-menu" class="burger-icon absolute z-[50] right-0 top-0 flex flex-col justify-center items-stretch gap-[8px] shrink-0 cursor-pointer h-16 desktop:h-[96px] mr-2">
  <div class="w-12 h-12 desktop:w-11 desktop:h-11 flex flex-col justify-center items-stretch gap-[5px]">
    <span class="line"></span>
    <span class="line"></span>
    <span class="line"></span>
  </div>
</button>

<!-- Nav drawer (slides in from right) -->
<nav id="nav-menu" aria-label="Site navigation" class="fixed inset-y-0 right-0 z-41 bg-lilac-200 flex flex-col pb-12" aria-hidden="true">
  <!-- Content -->
  <div class="mb-10 p-6 desktop:p-7 flex flex-col gap-12 items-start">
    <a
      href={rightCta.href}
      target={rightCta.openInNewTab ? '_blank' : undefined}
      rel={rightCta.openInNewTab ? 'noopener noreferrer' : undefined}
      class="inline-flex items-center justify-center h-11 px-6 rounded-full bg-lilac-200 border border-2 border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] text-ink-900 hover:bg-lilac-200/70 transition-colors"
    >
      {rightCta.label}
    </a>

    <!-- Nav links from Sanity -->
    <ul>
      {
        sidebarLinks.map(({ label, href, openInNewTab }) => (
          <li>
            <a href={href} target={openInNewTab ? '_blank' : undefined} rel={openInNewTab ? 'noopener noreferrer' : undefined} class="font-serif font-medium text-[36px] leading-[1.5] text-ink-900 hover:opacity-60 transition-opacity">
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<div id="nav-backdrop" class="fixed inset-0 z-40 bg-ink-900/40 opacity-0 pointer-events-none transition-opacity duration-300" aria-hidden="true"></div>

<style>
  #nav-menu {
    width: 0;
    opacity: 1;
    overflow: hidden;
    transition:
      width 0.35s ease-in-out,
      opacity 0.35s ease-in-out;
  }
  #nav-menu.is-open {
    width: 100%;
    opacity: 1;
    overflow-y: auto;
  }
  @media (min-width: 640px) {
    #nav-menu.is-open {
      width: 75%;
    }
  }
  @media (min-width: 1024px) {
    #nav-menu.is-open {
      width: 50%;
    }
  }

  .burger-icon .line {
    height: 3px;
    border-radius: 3px;
    background-color: var(--color-ink-900);
    transition: all 0.3s ease-in-out;
    z-index: 40;
  }
  .burger-icon.is-open {
    -webkit-transition: all 0.3s ease-in-out;
    -o-transition: all 0.3s ease-in-out;
    transition: all 0.3s ease-in-out;
    -webkit-transition-delay: 0.6s;
    -o-transition-delay: 0.6s;
    transition-delay: 0.6s;
    -webkit-transform: rotate(45deg);
    -ms-transform: rotate(45deg);
    -o-transform: rotate(45deg);
    transform: rotate(45deg);
  }

  .burger-icon.is-open .line:nth-child(2) {
    width: 0px;
  }

  .burger-icon.is-open .line:nth-child(1),
  .burger-icon.is-open .line:nth-child(3) {
    -webkit-transition-delay: 0.3s;
    -o-transition-delay: 0.3s;
    transition-delay: 0.3s;
  }

  .burger-icon.is-open .line:nth-child(1) {
    -webkit-transform: translateY(13px);
    -ms-transform: translateY(13px);
    -o-transform: translateY(13px);
    transform: translateY(13px);
  }

  .burger-icon.is-open .line:nth-child(3) {
    -webkit-transform: translateY(-13px) rotate(90deg);
    -ms-transform: translateY(-13px) rotate(90deg);
    -o-transform: translateY(-13px) rotate(90deg);
    transform: translateY(-13px) rotate(90deg);
  }

  /* Burger → X when menu is open */
  [aria-expanded='true'] .line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  [aria-expanded='true'] .line:nth-child(2) {
    opacity: 0;
  }
  [aria-expanded='true'] .line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById('nav-menu-toggle');
  const menu = document.getElementById('nav-menu');
  const backdrop = document.getElementById('nav-backdrop');

  function openMenu() {
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    backdrop?.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    backdrop?.classList.remove('opacity-100');
    document.body.style.overflow = '';
  }

  function toggleMenu() {
    if (toggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    } else {
      openMenu();
    }
  }

  toggle?.addEventListener('click', toggleMenu);
  // close?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    }
  });
</script>
