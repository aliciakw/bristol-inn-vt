---
import TextStyle from '@components/ui/TextStyle.astro';
import { AvailabilitySearchForm } from '@components/rooms/AvailabilitySearchForm';
import ButtonLink from '@components/ui/ButtonLink.astro';
import type { SanityImage } from '../../lib/sanity';
import { Image } from 'astro:assets';

interface Props {
  reservationHeading?: string;
  reservationHeadingIcon?: SanityImage;
  reservationDescription?: string;
  reservationImage?: SanityImage; // unused in this layout, kept for CMS compat
  logo?: string;
  seeAllHref?: string;
}

const { reservationHeading = 'Reserve your Stay, Today:', reservationHeadingIcon, reservationDescription, logo, seeAllHref } = Astro.props;
---

<section class="px-[var(--grid-margin)] desktop:px-0 py-12 bg-sand-200 rounded-b-[16px]">
  <div class="Section__inner">
    <!-- Heading block -->
    <div class="col-span-6 desktop:col-start-2 desktop:col-span-6 flex flex-col items-center gap-4 mb-8">
      {logo && <img src={logo} alt="" aria-hidden="true" class="w-24 h-24 object-contain" />}
      {
        reservationHeadingIcon && (
          <div class="w-20 h-20 flex items-center justify-center">
            <Image src={reservationHeadingIcon.url} alt={reservationHeadingIcon.alt} width={10} height={10} format="webp" loading="eager" class="w-full h-full object-contain" />
          </div>
        )
      }
      <TextStyle variant="h2" class="text-center">{reservationHeading}</TextStyle>
      {
        reservationDescription && (
          <TextStyle variant="paragraph" element="p" class="max-w-2xl">
            {reservationDescription}
          </TextStyle>
        )
      }
    </div>

    <!-- Search form -->
    <div class="col-span-6 desktop:col-start-2 desktop:col-span-6 flex flex-col items-center gap-6">
      <div class="w-full">
        <AvailabilitySearchForm client:visible navigateTo="/rooms-and-suites" />
      </div>
      {
        seeAllHref && (
          <ButtonLink href={seeAllHref} bg="lilac-200">
            See everything
          </ButtonLink>
        )
      }
    </div>
  </div>
</section>
