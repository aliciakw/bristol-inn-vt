---
import BaseLayout from '@layouts/BaseLayout.astro';
import { RoomBrowser } from '../components/rooms/RoomBrowser';
import { getRooms } from '../lib/hostaway';

const rooms = await getRooms();
const browserRooms = rooms.map(r => ({
  id: r.id,
  name: r.name,
  price: r.price,
  personCapacity: r.personCapacity,
  photo: r.photos[0] ?? { url: '', caption: '' },
  amenities: r.amenityNames.slice(0, 3),
}));
---

<BaseLayout title="Rooms — Bristol Inn" description="Browse all available rooms at Bristol Inn, Vermont.">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Our Rooms</h1>
    <RoomBrowser client:load rooms={browserRooms} />
  </div>
</BaseLayout>
