---
import BaseLayout from '@layouts/BaseLayout.astro';
import RoomCard from '../components/RoomCard.astro';
import { getRooms } from '../lib/hostaway';

const rooms = await getRooms();
---

<BaseLayout title="Rooms — Bristol Inn" description="Browse all available rooms at Bristol Inn, Vermont.">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Our Rooms</h1>
    {rooms.length === 0 ? (
      <p class="text-center text-gray-600">No rooms available at this time. Please check back soon.</p>
    ) : (
      <div class="grid grid-cols-1 tablet:grid-cols-2 desktop:grid-cols-3 gap-6">
        {rooms.map((room) => (
          <RoomCard
            id={room.id}
            name={room.name}
            rate={room.price}
            photo={room.photos[0] ?? { url: '', caption: '' }}
            amenities={room.amenityNames.slice(0, 3)}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
