---
import ImageComponent from '@components/ui/ImageComponent.astro';
import { buildSanityImageUrl } from '@lib/sanity';

interface Props {
  images: Array<{ url: string; alt: string }>;
  ctaLabel: string;
  ctaUrl: string;
}

const { images, ctaLabel, ctaUrl } = Astro.props;
---

<div id="hero-carousel" class="relative w-full min-h-[480px] tablet:min-h-[600px] overflow-hidden bg-gray-900">
  {
    images.map((img, index) => (
      <div class={`absolute inset-0 transition-opacity duration-700 ${index === 0 ? 'opacity-100' : 'opacity-0'}`} data-slide>
        <ImageComponent
          src={buildSanityImageUrl(img.url, { width: 1440, height: 800 })}
          srcset={`${buildSanityImageUrl(img.url, { width: 720, height: 400 })} 720w, ${buildSanityImageUrl(img.url, { width: 1440, height: 800 })} 1440w`}
          alt={img.alt}
          width={1440}
          height={800}
          loading={index === 0 ? 'eager' : 'lazy'}
          fadeIn={index === 0}
          class="w-full h-full"
          imgClass="w-full h-full object-cover"
        />
      </div>
    ))
  }

  <div class="absolute inset-0 bg-black/30 pointer-events-none"></div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-center text-white z-10">
    <a href={ctaUrl} class="inline-block bg-slate-700 text-white px-6 py-3 rounded hover:bg-slate-800">
      {ctaLabel}
    </a>
  </div>
</div>

<script>
  const slides = document.querySelectorAll<HTMLElement>('[data-slide]');

  if (slides.length > 1) {
    let currentIndex = 0;

    setInterval(() => {
      // eslint-disable-next-line security/detect-object-injection
      slides[currentIndex].classList.remove('opacity-100');
      // eslint-disable-next-line security/detect-object-injection
      slides[currentIndex].classList.add('opacity-0');

      currentIndex = (currentIndex + 1) % slides.length;

      // eslint-disable-next-line security/detect-object-injection
      slides[currentIndex].classList.remove('opacity-0');
      // eslint-disable-next-line security/detect-object-injection
      slides[currentIndex].classList.add('opacity-100');
    }, 5000);
  }
</script>
