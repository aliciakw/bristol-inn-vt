# Hostaway API configuration (server-only; keep secret)
HOSTAWAY_API_KEY=your-hostaway-api-key-here

# Prismic CMS configuration (server-only; keep secret)
PRISMIC_TOKEN=your-prismic-access-token-here

# Sentry error tracking (PUBLIC; visible to client)
PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here

# Google Analytics 4 (PUBLIC; visible to client)
PUBLIC_GA4_ID=your-ga4-measurement-id-here

# Sentry authentication token (server-only; keep secret)
SENTRY_AUTH_TOKEN=your-sentry-authentication-token-here