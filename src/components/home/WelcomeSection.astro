---
import { ArrowRight } from 'lucide-react';
import TextStyle from '@components/ui/TextStyle.astro';
import { buildSanityImageUrl, type SanityImage, type SanityResolvedLink } from '../../lib/sanity';
import ButtonLink from '@components/ui/ButtonLink.astro';
import ImageComponent from '@components/ui/ImageComponent.astro';

type WelcomeItem = {
  _key?: string;
  text?: string;
  cta?: SanityResolvedLink;
  image?: SanityImage;
};

interface Props {
  welcomeBackgroundColor?: string;
  welcomeHeading?: string;
  welcomeItems?: WelcomeItem[];
}

const { welcomeBackgroundColor = 'var(--color-sand-200)', welcomeHeading, welcomeItems = [] } = Astro.props;
---

<section id="welcome-section" class="Section relative min-h-[100vh]" style={{ background: welcomeBackgroundColor }}>
  <div id="welcome-section-content" class="Grid py-12">
    <div class="Grid__Row--inset-3 bg-white rounded-[16px] px-12 py-8">
      {
        welcomeHeading && welcomeItems.length < 1 && (
          <TextStyle variant="h1" element="h2" class="">
            <span class="text-ink-900">{welcomeHeading}</span>
          </TextStyle>
        )
      }
      {
        welcomeItems.length > 0 && (
          <TextStyle variant="h3" element="div" class="leading-[80px]">
            {welcomeItems.map((welcomeItem, index) => (
              <span>
                {index === 0 && welcomeHeading && (
                  <TextStyle variant="h1" element="h2" class="inline">
                    <span class="text-ink-900">{welcomeHeading}</span>
                  </TextStyle>
                )}
                {welcomeItem.image?.url && (
                  <ImageComponent
                    element="span"
                    src={buildSanityImageUrl(welcomeItem.image.url, { width: 900, height: 700 })}
                    srcset={`${buildSanityImageUrl(welcomeItem.image.url, { width: 450, height: 350 })} 450w, ${buildSanityImageUrl(welcomeItem.image.url, { width: 900, height: 700 })} 900w`}
                    sizes="150px"
                    alt={welcomeItem.image.alt}
                    width={900}
                    height={700}
                    loading="lazy"
                    class="inline-block w-[134px] tablet:w-[150px] aspect-[4/3] mr-4 overflow-hidden rounded-xl align-middle"
                    imgClass="w-full h-full object-cover"
                    fadeIn
                  />
                )}
                {welcomeItem.text && <span>{welcomeItem.text} </span>}
                {welcomeItem.cta?.href && (
                  <span class="cta-arrow-group inline-flex items-center align-middle gap-1 mr-6">
                    <ArrowRight size={28} className="cta-arrow text-ink-900" aria-hidden="true" />
                    <ButtonLink
                      size="default"
                      bg="sand-200"
                      class="inline-flex align-middle"
                      href={welcomeItem.cta.href}
                      target={welcomeItem.cta.openInNewTab ? '_blank' : undefined}
                      rel={welcomeItem.cta.openInNewTab ? 'noopener noreferrer' : undefined}
                    >
                      {welcomeItem.cta.label}
                    </ButtonLink>
                  </span>
                )}
              </span>
            ))}
          </TextStyle>
        )
      }
    </div>
  </div>
</section>

<style></style>

<style is:global>
  .cta-arrow {
    transition: transform 0.2s ease;
    margin-right: 6px;
  }

  .cta-arrow-group:hover .cta-arrow {
    transform: translateX(2px);
  }
</style>

<script></script>
