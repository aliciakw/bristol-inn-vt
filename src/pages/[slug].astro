---
import { getPages, getPage } from '../lib/sanity';
import BaseLayout from '@layouts/BaseLayout.astro';
import SliceZone from '../components/SliceZone.astro';
import PageHeader from '../components/PageHeader.astro';

export async function getStaticPaths() {
  // Slugs handled by dedicated page files — exclude them from this catch-all
  const dedicatedSlugs = new Set(['rooms-and-suites']);
  const pages = await getPages();
  return pages
    .filter((page) => !dedicatedSlugs.has(page.uid))
    .map((page) => ({
      params: { slug: page.uid },
      props: { slug: page.uid },
    }));
}

type Props = { slug: string };
const { slug } = Astro.props;
const page = await getPage(slug);
const pageTitle = page.title || 'Untitled';
---

<BaseLayout title={`${pageTitle} — Bristol Inn`} meta={page?.meta} backgroundColor="white" navigationVariant="transparent" offsetNavigation>
  {page?.pageHeader && <PageHeader block={page.pageHeader} className="pb-16" />}

  <div class="Section mt-12">
    <div class="Section__inner">
      <div class="row-span-1 col-span-6 desktop:col-span-8">
        <SliceZone blocks={page.body} />
      </div>
    </div>
  </div>
</BaseLayout>
