---
/**
 * RoomCard — purely presentational room listing card.
 *
 * Caller is responsible for slicing amenities to at most 3 before passing.
 * RoomCard renders all amenities it receives without further filtering.
 *
 * Props derive from HostawayRoom fields (see src/lib/hostaway.ts):
 *   id        → room.id
 *   name      → room.name
 *   rate      → room.price
 *   photo     → room.photos[0]
 *   amenities → room.amenityNames.slice(0, 3)
 */

import { Image } from 'astro:assets';
import AmenityBadge from './AmenityBadge.astro';

interface Props {
  id: number;
  name: string;
  /** Base nightly rate in dollars — formatted as integer, no decimals */
  rate: number;
  photo: { url: string; caption: string };
  amenities: string[];
}

const { id, name, rate, photo, amenities } = Astro.props;
const formattedRate = Math.round(rate);
---

<article class="bg-white rounded-lg overflow-hidden shadow-sm border border-ink-900 hover:shadow-md">
  <Image src={photo.url} alt={photo.caption || name} width={600} height={400} format="webp" loading="lazy" class="w-full object-cover" />
  <div class="p-4 flex flex-col gap-3">
    <h3 class="text-xl font-bold">{name}</h3>
    <p class="text-base font-normal text-gray-700">From ${formattedRate} / night</p>
    <div class="flex flex-wrap gap-2">
      {amenities.map((a) => <AmenityBadge label={a} />)}
    </div>
    <a href={`/rooms/${id}`} class="inline-block mt-2 text-slate-700 font-normal underline-offset-2 hover:underline">More Info</a>
    <a href={`https://www.hostaway.com/book/${id}`} class="inline-block mt-2 text-slate-700 font-normal underline-offset-2 hover:underline">Book Now</a>
  </div>
</article>
