---
interface Props {
  variant?: 'default' | 'transparent';
  bookingUrl?: string;
}

const {
  variant = 'default',
  bookingUrl = '/rooms',
} = Astro.props;

const isTransparent = variant === 'transparent';
---

<header
  id="nav-top-bar"
  class:list={[
    'w-full h-16 desktop:h-[96px] sticky top-0 z-40 flex items-center shrink-0',
    isTransparent ? 'bg-transparent' : 'bg-sand-100',
  ]}
>
  <!-- Left: hamburger (+ Contact Us on tablet+) -->
  <div class="flex items-center gap-3 desktop:gap-6 pl-4 desktop:pl-6">
    <button
      id="nav-menu-toggle"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-menu"
      class="flex flex-col justify-center items-center gap-[5px] w-12 h-12 shrink-0 cursor-pointer rounded-full bg-khaki-200 desktop:bg-transparent desktop:w-10 desktop:h-10"
    >
      <span class="block w-5 desktop:w-6 h-[2px] bg-ink-900 rounded-full transition-transform origin-center" data-bar="top"></span>
      <span class="block w-5 desktop:w-6 h-[2px] bg-ink-900 rounded-full transition-opacity" data-bar="mid"></span>
      <span class="block w-5 desktop:w-6 h-[2px] bg-ink-900 rounded-full transition-transform origin-center" data-bar="bot"></span>
    </button>

    <a
      href="/contact"
      class="hidden desktop:inline-flex items-center justify-center h-11 px-5 rounded-full bg-khaki-200 border border-ink-900 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] text-ink-900 whitespace-nowrap hover:bg-khaki-300 transition-colors"
    >
      Contact Us
    </a>
  </div>

  <!-- Center: logo -->
  <div class="absolute left-1/2 -translate-x-1/2 text-center pointer-events-none select-none">
    <a href="/" class="pointer-events-auto">
      <p class="font-serif font-medium text-[30px] desktop:text-[2.4375rem] leading-none tracking-[0.01em] text-ink-900">
        The Bristol Inn
      </p>
      <p class="font-serif font-normal text-[11px] desktop:text-[0.875rem] leading-[1.1] tracking-[0.01em] uppercase text-ink-900 mt-0.5">
        19 Main Street, Bristol, Vermont, USA
      </p>
    </a>
  </div>

  <!-- Right: Reserve A Room (desktop only) -->
  <div class="hidden desktop:flex items-center ml-auto pr-4 desktop:pr-16">
    <a
      href={bookingUrl}
      class="inline-flex items-center justify-center h-11 px-5 rounded-full bg-forest-400 border border-sand-100 font-serif font-medium text-[21px] leading-none tracking-[-0.021em] text-sand-100 whitespace-nowrap hover:opacity-90 transition-opacity"
    >
      Reserve A Room
    </a>
  </div>
</header>

<!-- Nav drawer (slides in from left) -->
<nav
  id="nav-menu"
  aria-label="Site navigation"
  class="fixed inset-y-0 left-0 z-50 w-full tablet:w-3/4 desktop:w-1/2 bg-lilac-200 flex flex-col p-8 -translate-x-full transition-width transition-transform duration-300 ease-in-out"
  aria-hidden="true"
>
  <div class="flex items-center justify-between mb-12">
    <p class="font-serif font-medium text-[1.5rem] leading-none text-ink-900">The Bristol Inn</p>
    <button
      id="nav-menu-close"
      type="button"
      aria-label="Close navigation menu"
      class="flex items-center justify-center w-10 h-10 cursor-pointer"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M2 2L18 18M18 2L2 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <ul class="flex flex-col gap-8">
    <li>
      <a href="/" class="font-serif font-medium text-[2rem] leading-none text-ink-900 hover:text-forest-400 transition-colors">
        Home
      </a>
    </li>
    <li>
      <a href="/rooms" class="font-serif font-medium text-[2rem] leading-none text-ink-900 hover:text-forest-400 transition-colors">
        Rooms
      </a>
    </li>
    <li>
      <a href="/contact" class="font-serif font-medium text-[2rem] leading-none text-ink-900 hover:text-forest-400 transition-colors">
        Contact
      </a>
    </li>
  </ul>

  <div class="mt-auto">
    <a
      href={bookingUrl}
      class="inline-flex items-center justify-center h-14 px-8 rounded-full bg-forest-400 border border-sand-100 font-serif font-medium text-[21px] leading-none text-sand-100"
    >
      Reserve A Room
    </a>
  </div>
</nav>

<div
  id="nav-backdrop"
  class="fixed inset-0 z-40 bg-ink-900/40 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<script>
  const toggle = document.getElementById('nav-menu-toggle');
  const close = document.getElementById('nav-menu-close');
  const menu = document.getElementById('nav-menu');
  const backdrop = document.getElementById('nav-backdrop');

  function openMenu() {
    menu?.classList.remove('-translate-x-full');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    backdrop?.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('-translate-x-full');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    backdrop?.classList.remove('opacity-100');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    }
  });
</script>
